	/// Receita de ingressos confirmados (Limber e-commerce). Exclui locação de equipamentos.
	/// DEDUPLICAÇÃO: usa ValorUnitario (único por linha) com filtro Status=Aprovada.
	measure 'Receita Limber' =
			VAR _anos_sel = ALLSELECTED('01_Calendário'[Ano])
			VAR _ano = IF(COUNTROWS(_anos_sel) = 1, MINX(_anos_sel, '01_Calendário'[Ano]), YEAR(TODAY()))
			RETURN
			CALCULATE(
			    SUM(Limber_Vendas[ValorUnitario]),
			    Limber_Vendas[Status] = "Aprovada",
			    NOT Limber_Vendas[Categoria] IN {"Aluguel de Boia - LOCAL", "Aluguel de Armários", "Pó Colorido"},
			    KEEPFILTERS('01_Calendário'[Ano] = _ano)
			)
		formatString: R$ #,##0.00
		displayFolder: Funil de Vendas
		lineageTag: 50a46ec4-9919-4b18-8a69-211af094f4ee

	/// Qtd de pedidos confirmados (Limber) — conta Localizadores únicos com Status=Aprovada.
	/// DEDUPLICAÇÃO: DISTINCTCOUNT(Localizador) evita contar múltiplas linhas do mesmo pedido.
	measure 'Vendas Confirmadas' =
			CALCULATE(
			    DISTINCTCOUNT(Limber_Vendas[Localizador]),
			    Limber_Vendas[Status] = "Aprovada"
			)
		formatString: #,##0
		displayFolder: Funil de Vendas
		lineageTag: f8178bd0-36c2-4cf1-888b-01c98c6a075f

	/// Soma bruta do investimento Meta Ads sem lógica de ano. Uso interno para cálculos YoY.
	measure '_Meta Invest Bruto' = SUM(Meta_Ads_Campanhas[spend])
		formatString: R$ #,##0.00
		displayFolder: Utilitários
		lineageTag: 6576ea13-9526-43c7-869a-3a774e8483e9

	/// Soma bruta do investimento Google Ads sem lógica de ano. Uso interno para cálculos YoY.
	measure '_GA Invest Bruto' = DIVIDE(SUM(Google_Ads_Campanhas[cost_micros]), 1000000)
