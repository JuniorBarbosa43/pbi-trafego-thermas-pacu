	/// Gráfico SVG: investimento mensal YoY (ano anterior vs ano atual). Renderizado via HTML Content visual.
	measure 'YoY Invest Mensal' =
			VAR _anoMax = MAXX(ALLSELECTED('01_Calendário'), '01_Calendário'[Ano])
			VAR _anoAnt = _anoMax - 1
			VAR _meses = GENERATESERIES(1, 12, 1)
			VAR _dados = ADDCOLUMNS(
			    _meses,
			    "Abrev", SWITCH([Value],
			        1,"Jan",2,"Fev",3,"Mar",4,"Abr",5,"Mai",6,"Jun",
			        7,"Jul",8,"Ago",9,"Set",10,"Out",11,"Nov",12,"Dez",""),
			    "CY", CALCULATE(
			        SUM(Meta_Ads_Campanhas[spend]) + DIVIDE(SUM(Google_Ads_Campanhas[cost_micros]), 1000000),
			        REMOVEFILTERS('01_Calendário'),
			        '01_Calendário'[Ano] = _anoMax,
			        TREATAS({[Value]}, '01_Calendário'[MêsNúmero])
			    ),
			    "LY", CALCULATE(
			        SUM(Meta_Ads_Campanhas[spend]) + DIVIDE(SUM(Google_Ads_Campanhas[cost_micros]), 1000000),
			        REMOVEFILTERS('01_Calendário'),
			        '01_Calendário'[Ano] = _anoAnt,
			        TREATAS({[Value]}, '01_Calendário'[MêsNúmero])
			    )
			)
			VAR _maxRaw = MAXX(_dados, MAX([CY], [LY]))
			VAR _maxV = MAX(1, _maxRaw)
			VAR _cH = 90
			VAR _cX = 36
			VAR _cY = 22
			VAR _gW = 54
			VAR _bW = 20
			VAR _baseY = _cY + _cH
			VAR _bars = CONCATENATEX(
			    TOPN(12, _dados, [Value], ASC),
			    VAR _n = [Value]
			    VAR _gx = _cX + (_n - 1) * _gW
			    VAR _ly = [LY]
			    VAR _cy = [CY]
			    VAR _lyH = INT(_ly / _maxV * _cH)
			    VAR _cyH = INT(_cy / _maxV * _cH)
			    VAR _lyY = _baseY - _lyH
			    VAR _cyY = _baseY - _cyH
			    VAR _lx = _gx + 3
			    VAR _cx = _gx + 26
			    VAR _lyFmt = IF(_ly >= 1000, FORMAT(_ly / 1000, "#,0.0") & "K", FORMAT(_ly, "#,0"))
			    VAR _cyFmt = IF(_cy >= 1000, FORMAT(_cy / 1000, "#,0.0") & "K", FORMAT(_cy, "#,0"))
			    RETURN
			        IF(_lyH > 0, "<rect x='" & _lx & "' y='" & _lyY & "' width='" & _bW & "' height='" & _lyH & "' fill='#5B7FA6' rx='2'/>", "") &
			        IF(_cyH > 0, "<rect x='" & _cx & "' y='" & _cyY & "' width='" & _bW & "' height='" & _cyH & "' fill='#F97316' rx='2'/>", "") &
			        IF(_lyH > 14, "<text x='" & (_lx + 10) & "' y='" & (_lyY - 3) & "' text-anchor='middle' font-size='7' fill='#8B9CB3' font-family='Segoe UI,sans-serif'>" & _lyFmt & "</text>", "") &
			        IF(_cyH > 14, "<text x='" & (_cx + 10) & "' y='" & (_cyY - 3) & "' text-anchor='middle' font-size='7' fill='#F97316' font-family='Segoe UI,sans-serif'>" & _cyFmt & "</text>", "") &
			        "<text x='" & (_gx + 27) & "' y='" & (_baseY + 12) & "' text-anchor='middle' font-size='8' fill='#8B9CB3' font-family='Segoe UI,sans-serif'>" & [Abrev] & "</text>"
			)
			VAR _mid50Y = INT(_cY + _cH * 0.5)
			VAR _gridLines =
			    "<line x1='" & _cX & "' y1='" & _mid50Y & "' x2='" & (_cX + 12 * _gW) & "' y2='" & _mid50Y & "' stroke='#21262D' stroke-width='1' stroke-dasharray='3,3'/>" &
			    "<line x1='" & _cX & "' y1='" & _cY & "' x2='" & (_cX + 12 * _gW) & "' y2='" & _cY & "' stroke='#21262D' stroke-width='1' stroke-dasharray='3,3'/>"
			VAR _midLbl = IF(_maxV >= 2000, FORMAT(_maxV / 2000, "#,0.0") & "K", FORMAT(_maxV / 2, "#,0"))
			VAR _topLbl = IF(_maxV >= 1000, FORMAT(_maxV / 1000, "#,0.0") & "K", FORMAT(_maxV, "#,0"))
			VAR _svg =
			    "<svg xmlns='http://www.w3.org/2000/svg' width='100%' viewBox='0 0 700 155'>" &
			    "<text x='350' y='13' text-anchor='middle' font-family='Segoe UI,sans-serif' font-size='11' font-weight='bold' fill='#C9D1D9'>Investimento Mensal: " & _anoAnt & " vs " & _anoMax & "</text>" &
			    "<line x1='" & _cX & "' y1='" & _cY & "' x2='" & _cX & "' y2='" & _baseY & "' stroke='#30363D' stroke-width='1'/>" &
			    "<line x1='" & _cX & "' y1='" & _baseY & "' x2='" & (_cX + 12 * _gW) & "' y2='" & _baseY & "' stroke='#30363D' stroke-width='1'/>" &
			    "<text x='" & (_cX - 4) & "' y='" & (_cY + 4) & "' text-anchor='end' font-size='7' fill='#8B9CB3' font-family='Segoe UI,sans-serif'>" & _topLbl & "</text>" &
			    "<text x='" & (_cX - 4) & "' y='" & (_mid50Y + 4) & "' text-anchor='end' font-size='7' fill='#8B9CB3' font-family='Segoe UI,sans-serif'>" & _midLbl & "</text>" &
			    "<text x='" & (_cX - 4) & "' y='" & (_baseY + 4) & "' text-anchor='end' font-size='7' fill='#8B9CB3' font-family='Segoe UI,sans-serif'>0</text>" &
			    _gridLines &
			    _bars &
			    "<rect x='230' y='138' width='10' height='10' fill='#5B7FA6' rx='2'/>" &
			    "<text x='244' y='147' font-family='Segoe UI,sans-serif' font-size='9' fill='#8B9CB3'>" & _anoAnt & "</text>" &
			    "<rect x='300' y='138' width='10' height='10' fill='#F97316' rx='2'/>" &
			    "<text x='314' y='147' font-family='Segoe UI,sans-serif' font-size='9' fill='#F97316'>" & _anoMax & "</text>" &
			    "</svg>"
			RETURN IF(_maxRaw <= 0, "", _svg)
		displayFolder: Gráficos
		lineageTag: chart-yoy01-4c76-a3b9-000500001111

