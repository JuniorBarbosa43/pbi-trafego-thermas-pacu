			RETURN
			CALCULATE(SUM(Meta_Ads_Campanhas[clicks]) + SUM(Google_Ads_Campanhas[clicks]), REMOVEFILTERS('01_Calendário'[Ano]), '01_Calendário'[Ano] = _anoMax - 1)
		formatString: #,##0
		displayFolder: Comparativos
		lineageTag: 7d3bb7bb-aa01-4c76-a3b9-0001000010ad

	/// Variação percentual YoY dos cliques totais em Ads.
	measure 'Cliques Ads ΔYoY' =
			VAR _anoMax = MAXX(ALLSELECTED('01_Calendário'), '01_Calendário'[Ano])
			VAR _atual = CALCULATE(SUM(Meta_Ads_Campanhas[clicks]) + SUM(Google_Ads_Campanhas[clicks]), REMOVEFILTERS('01_Calendário'[Ano]), '01_Calendário'[Ano] = _anoMax)
			VAR _anterior = [Cliques Ads Ano Anterior]
			RETURN DIVIDE(_atual - _anterior, _anterior)
		formatString: +0.0%;-0.0%;0.0%
