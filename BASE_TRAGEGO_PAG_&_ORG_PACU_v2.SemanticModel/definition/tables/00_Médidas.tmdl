	/// Receita por dia bom — normaliza a receita pelo clima favorável.
	measure 'Receita por Dia Bom' = DIVIDE([Receita Limber], [Clima Dias Bons Parque])
		formatString: "R$" #,##0.00
		displayFolder: Clima × Performance
		lineageTag: clima-rec-dd01-4c76-RECDB000001

	/// Investimento por dia bom — custo real por dia favorável de parque.
	measure 'Investimento por Dia Bom' = DIVIDE([Total Investimento Ads], [Clima Dias Bons Parque])
		formatString: "R$" #,##0.00
		displayFolder: Clima × Performance
		lineageTag: clima-inv-dd01-4c76-INVDB000001

	/// Classificação textual do clima mensal com base no percentual de dias bons.
	measure 'Clima Categoria' =
			SWITCH(
				TRUE(),
				[Clima % Dias Bons] >= 0.7, "Ótimo",
				[Clima % Dias Bons] >= 0.5, "Bom",
				[Clima % Dias Bons] >= 0.3, "Regular",
				"Ruim"
			)
		displayFolder: Clima × Performance
		lineageTag: clima-cat-dd01-4c76-CATEG000001

	/// Receita de todas as categorias de acesso não exibidas nos cards Adulto/Infantil/Kids: Especial, Idosos, Teens, Minha Mãe Paga Meia, Ingresso, Ingresso de Acesso.
	measure 'Receita Outros Ingressos' =
			VAR _anos_sel = ALLSELECTED('01_Calendário'[Ano])
			VAR _ano = IF(COUNTROWS(_anos_sel) = 1, MINX(_anos_sel, '01_Calendário'[Ano]), YEAR(TODAY()))
			RETURN
			CALCULATE(
			    SUM(Limber_Vendas[ValorUnitario]),
			    Limber_Vendas[Status] = "Aprovada",
			    Limber_Vendas[Categoria] IN {"Especial", "Idosos", "Teens", "Minha Mãe Paga Meia", "Ingresso", "Ingresso de Acesso"},
			    KEEPFILTERS('01_Calendário'[Ano] = _ano)
			)
		formatString: R$ #,##0.00
		displayFolder: E-commerce\Categorias
		lineageTag: ec000012-1111-2222-3333-ECOMM000012

	/// Quantidade de pessoas nas categorias de acesso não exibidas nos cards principais.
	measure 'Qtd Outros Ingressos' =
			VAR _anos_sel = ALLSELECTED('01_Calendário'[Ano])
			VAR _ano = IF(COUNTROWS(_anos_sel) = 1, MINX(_anos_sel, '01_Calendário'[Ano]), YEAR(TODAY()))
			RETURN
			CALCULATE(
			    SUM(Limber_Vendas[QtdPessoas]),
			    Limber_Vendas[Status] = "Aprovada",
			    Limber_Vendas[Categoria] IN {"Especial", "Idosos", "Teens", "Minha Mãe Paga Meia", "Ingresso", "Ingresso de Acesso"},
			    KEEPFILTERS('01_Calendário'[Ano] = _ano)
			)
		formatString: #,##0
		displayFolder: E-commerce\Categorias
		lineageTag: ec000013-1111-2222-3333-ECOMM000013

	/// Diagnóstico: mostra a data mais antiga de venda aprovada no ano anterior ao selecionado.
	/// Use em um card. Se aparecer depois de 01/01 do ano anterior, há dados históricos incompletos.
	measure 'Diagnóstico: Início Dados AA' =
			VAR _anos_sel = ALLSELECTED('01_Calendário'[Ano])
			VAR _ano = IF(COUNTROWS(_anos_sel) = 1, MINX(_anos_sel, '01_Calendário'[Ano]), YEAR(TODAY()))
			VAR _min_date = CALCULATE(
			    MIN(Limber_Vendas[DateKey]),
			    Limber_Vendas[Status] = "Aprovada",
			    REMOVEFILTERS('01_Calendário'),
			    '01_Calendário'[Ano] = _ano - 1
			)
			VAR _max_date = CALCULATE(
			    MAX(Limber_Vendas[DateKey]),
			    Limber_Vendas[Status] = "Aprovada",
			    REMOVEFILTERS('01_Calendário'),
			    '01_Calendário'[Ano] = _ano - 1
			)
			VAR _meses = CALCULATE(
			    DISTINCTCOUNT('01_Calendário'[MêsNúmero]),
			    Limber_Vendas[Status] = "Aprovada",
			    REMOVEFILTERS('01_Calendário'),
			    '01_Calendário'[Ano] = _ano - 1
			)
			RETURN
			IF(
			    ISBLANK(_min_date),
			    "⚠ Sem dados para " & (_ano - 1),
			    FORMAT(_min_date, "dd/MM/yyyy") & " → " & FORMAT(_max_date, "dd/MM/yyyy") &
			    " (" & _meses & " meses)"
			)
		displayFolder: E-commerce\Diagnóstico
		lineageTag: ec000110-1111-2222-3333-ECOMM000110

	/// Receita de produtos físicos (aluguel de equipamentos e consumíveis). Deve aparecer em card separado acima de Outros Ingressos.
	measure 'Receita Produtos' =
			VAR _anos_sel = ALLSELECTED('01_Calendário'[Ano])
			VAR _ano = IF(COUNTROWS(_anos_sel) = 1, MINX(_anos_sel, '01_Calendário'[Ano]), YEAR(TODAY()))
			RETURN
			CALCULATE(
			    SUM(Limber_Vendas[ValorUnitario]),
			    Limber_Vendas[Status] = "Aprovada",
			    Limber_Vendas[Categoria] IN {"Aluguel de Armários", "Aluguel de Boia - LOCAL", "Pó Colorido"},
			    KEEPFILTERS('01_Calendário'[Ano] = _ano)
			)
		formatString: R$ #,##0.00
		displayFolder: E-commerce\Categorias
		lineageTag: ec000014-1111-2222-3333-ECOMM000014

	/// Quantidade de itens de produtos físicos alugados (armários + boias).
	measure 'Qtd Produtos' =
			VAR _anos_sel = ALLSELECTED('01_Calendário'[Ano])
			VAR _ano = IF(COUNTROWS(_anos_sel) = 1, MINX(_anos_sel, '01_Calendário'[Ano]), YEAR(TODAY()))
			RETURN
			CALCULATE(
			    SUM(Limber_Vendas[QtdArmario]) + SUM(Limber_Vendas[QtdBoia]),
			    Limber_Vendas[Status] = "Aprovada",
			    KEEPFILTERS('01_Calendário'[Ano] = _ano)
			)
		formatString: #,##0
		displayFolder: E-commerce\Categorias
		lineageTag: ec000015-1111-2222-3333-ECOMM000015

