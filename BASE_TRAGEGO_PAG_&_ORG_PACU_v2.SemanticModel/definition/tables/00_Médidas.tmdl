	/// FB Saldo Seguidores do ano anterior (para comparativo YoY).
	measure 'FB Saldo Seguidores Ano Anterior' =
			VAR _anoMax = MAXX(ALLSELECTED('01_Calendário'), '01_Calendário'[Ano])
			VAR _novos = CALCULATE(
			    SUM(Meta_Organico_FB[valor]),
			    Meta_Organico_FB[metrica] = "page_daily_follows_unique",
			    REMOVEFILTERS('01_Calendário'[Ano]),
			    '01_Calendário'[Ano] = _anoMax - 1
			)
			VAR _perdidos = CALCULATE(
			    SUM(Meta_Organico_FB[valor]),
			    Meta_Organico_FB[metrica] = "page_daily_unfollows_unique",
			    REMOVEFILTERS('01_Calendário'[Ano]),
			    '01_Calendário'[Ano] = _anoMax - 1
			)
			RETURN IF(ISBLANK(_novos), BLANK(), _novos - IF(ISBLANK(_perdidos), 0, _perdidos))
		formatString: #,##0
		displayFolder: Orgânico FB\Comparativos
		lineageTag: 7700aaaa-bbbb-cccc-dddd-FB0000000010

	/// Delta YoY do Saldo de Seguidores FB — mesmo período (YTD vs YTD).
	measure 'FB Saldo Seguidores ΔYoY' =
			VAR _anoMax = MAXX(ALLSELECTED('01_Calendário'), '01_Calendário'[Ano])
			VAR _mesMax = IF(_anoMax = YEAR(TODAY()), MONTH(TODAY()), 12)
			VAR _cy_nov = CALCULATE(SUM(Meta_Organico_FB[valor]), Meta_Organico_FB[metrica] = "page_daily_follows_unique", REMOVEFILTERS('01_Calendário'[Ano]), '01_Calendário'[Ano] = _anoMax)
			VAR _cy_per = CALCULATE(SUM(Meta_Organico_FB[valor]), Meta_Organico_FB[metrica] = "page_daily_unfollows_unique", REMOVEFILTERS('01_Calendário'[Ano]), '01_Calendário'[Ano] = _anoMax)
			VAR _cy = _cy_nov - _cy_per
			VAR _ly_nov = CALCULATE(SUM(Meta_Organico_FB[valor]), Meta_Organico_FB[metrica] = "page_daily_follows_unique", REMOVEFILTERS('01_Calendário'[Ano]), '01_Calendário'[Ano] = _anoMax - 1, '01_Calendário'[MêsNúmero] <= _mesMax)
			VAR _ly_per = CALCULATE(SUM(Meta_Organico_FB[valor]), Meta_Organico_FB[metrica] = "page_daily_unfollows_unique", REMOVEFILTERS('01_Calendário'[Ano]), '01_Calendário'[Ano] = _anoMax - 1, '01_Calendário'[MêsNúmero] <= _mesMax)
			VAR _ly = _ly_nov - _ly_per
			RETURN IF(_ly <> 0, DIVIDE(_cy - _ly, ABS(_ly)), BLANK())
		formatString: +0.0%;-0.0%;0.0%
		displayFolder: Orgânico FB
		lineageTag: 5500aaaa-bbbb-cccc-dddd-FB0000000012

