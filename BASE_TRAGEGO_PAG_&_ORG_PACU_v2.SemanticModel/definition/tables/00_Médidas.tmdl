	/// Ticket médio por pedido (Localizador único), filtrado pelo ano selecionado.
	measure 'Ticket Médio Geral' =
			VAR _receita = [Receita Limber]
			VAR _pedidos = [Pedidos Confirmados]
			RETURN DIVIDE(_receita, _pedidos)
		formatString: R$ #,##0.00
		displayFolder: Funil de Vendas
		lineageTag: 7c69b673-4e7d-4a80-97a9-a3c0da8f1b3a

	/// Investimento Meta Ads. Default = ano corrente via SELECTEDVALUE quando slicer não filtrado.
	measure 'Meta Investimento Total' =
			VAR _anos_sel = ALLSELECTED('01_Calendário'[Ano])
			VAR _ano = IF(COUNTROWS(_anos_sel) = 1, MINX(_anos_sel, '01_Calendário'[Ano]), YEAR(TODAY()))
			RETURN
			CALCULATE(
			    SUM(Meta_Ads_Campanhas[spend]),
			    KEEPFILTERS('01_Calendário'[Ano] = _ano)
			)
		formatString: R$ #,##0.00
		displayFolder: Meta Ads
		lineageTag: 0d93640e-f0cf-40f0-93c3-5154a49fc888

	/// Impressões Meta Ads. Filtrado pelo ano selecionado (ou ano corrente por padrão).
	measure 'Meta Impressões' =
			VAR _anos_sel = ALLSELECTED('01_Calendário'[Ano])
			VAR _ano = IF(COUNTROWS(_anos_sel) = 1, MINX(_anos_sel, '01_Calendário'[Ano]), YEAR(TODAY()))
			RETURN
			CALCULATE(
			    SUM(Meta_Ads_Campanhas[impressions]),
			    KEEPFILTERS('01_Calendário'[Ano] = _ano)
			)
		formatString: #,##0
		displayFolder: Meta Ads
		lineageTag: d7770f95-a0a0-433f-8f29-f8f7dffcb57d

