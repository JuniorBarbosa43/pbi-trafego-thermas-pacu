	/// Delta YoY de Engajamento FB — mesmo período (YTD vs YTD).
	measure 'FB Engajamento ΔYoY' =
			VAR _anoMax = MAXX(ALLSELECTED('01_Calendário'), '01_Calendário'[Ano])
			VAR _mesMax = IF(_anoMax = YEAR(TODAY()), MONTH(TODAY()), 12)
			VAR _cy = CALCULATE(SUM(Meta_Organico_FB[valor]), Meta_Organico_FB[metrica] = "page_post_engagements", REMOVEFILTERS('01_Calendário'[Ano]), '01_Calendário'[Ano] = _anoMax)
			VAR _ly = CALCULATE(SUM(Meta_Organico_FB[valor]), Meta_Organico_FB[metrica] = "page_post_engagements", REMOVEFILTERS('01_Calendário'[Ano]), '01_Calendário'[Ano] = _anoMax - 1, '01_Calendário'[MêsNúmero] <= _mesMax)
			RETURN IF(_ly > 0, DIVIDE(_cy - _ly, _ly), BLANK())
