	/// ═══════════════════════════════════════════════════════════
	/// CHART V9 GRANDE — Spend vs Revenue 12 meses (largura inteira)
	/// ═══════════════════════════════════════════════════════════
	measure '_Chart Big Spend Revenue V9' =
			VAR _ano = MAX('01_Calendário'[Ano])
			VAR _tbl =
			    CALCULATETABLE(
			        ADDCOLUMNS(VALUES('01_Calendário'[Mês]),
			            "MesNum", CALCULATE(MAX('01_Calendário'[MêsNúmero])),
			            "Spend", COALESCE([Total Investimento Ads], 0),
			            "Rev", COALESCE([Receita Conversões Ads], 0),
			            "Roas", COALESCE([ROAS Conversão Ads], 0)),
			        '01_Calendário'[Ano] = _ano
			    )
			VAR _maxBar = MAXX(_tbl, [Spend])
			VAR _maxLine = MAXX(_tbl, [Rev])
			VAR _maxBarSafe = IF(_maxBar <= 0, 1, _maxBar)
			VAR _maxLineSafe = IF(_maxLine <= 0, 1, _maxLine)
			VAR _w = 800
			VAR _h = 270
			VAR _xLeft = 60
			VAR _xRight = 60
			VAR _bw = 38
			VAR _step = (_w - _xLeft - _xRight) / 12
			VAR _baseY = 220
			VAR _topY = 30
			VAR _bars =
			    CONCATENATEX(_tbl,
			        VAR _x = _xLeft + ([MesNum] - 1) * _step + (_step - _bw) / 2
			        VAR _hSpend = DIVIDE([Spend], _maxBarSafe) * (_baseY - _topY)
			        VAR _y = _baseY - _hSpend
			        VAR _label = SWITCH(TRUE(),
			            [Spend] >= 1000000, "R$" & FORMAT([Spend]/1000000, "0.0") & "M",
			            [Spend] >= 1000, "R$" & FORMAT([Spend]/1000, "0") & "K",
			            "R$" & FORMAT([Spend], "0"))
			VAR _roasLbl = IF([Roas] > 0, FORMAT([Roas], "0.0") & "x", "")
			VAR _roasColor = SWITCH(TRUE(), [Roas] >= 5, "#22c55e", [Roas] >= 3, "#FBBF24", [Roas] > 0, "#ef4444", "#94A3B8")
			        RETURN
			        "<rect x='" & FORMAT(_x, "0") & "' y='" & FORMAT(_y, "0") & "' width='" & _bw & "' height='" & FORMAT(_hSpend, "0") & "' fill='#E05A00' rx='3'/>" &
			        IF(_hSpend > 22, "<text x='" & FORMAT(_x + _bw/2, "0") & "' y='" & FORMAT(_y + 14, "0") & "' text-anchor='middle' font-size='11' font-weight='bold' fill='#fff'>" & _label & "</text>", "<text x='" & FORMAT(_x + _bw/2, "0") & "' y='" & FORMAT(_y - 6, "0") & "' text-anchor='middle' font-size='10' fill='#FED7AA' font-weight='bold'>" & _label & "</text>") &
			        "<text x='" & FORMAT(_x + _bw/2, "0") & "' y='" & FORMAT(_baseY + 16, "0") & "' text-anchor='middle' font-size='11' fill='#cbd5e1' font-weight='bold'>" & UPPER(LEFT('01_Calendário'[Mês], 3)) & "</text>" &
			        IF([Roas] > 0, "<text x='" & FORMAT(_x + _bw/2, "0") & "' y='" & FORMAT(_baseY + 30, "0") & "' text-anchor='middle' font-size='10' fill='" & _roasColor & "' font-weight='bold'>" & _roasLbl & "</text>", ""),
			        "", [MesNum], ASC)
			VAR _line_pts =
			    CONCATENATEX(_tbl,
			        VAR _x = _xLeft + ([MesNum] - 1) * _step + _step/2
			        VAR _y = _baseY - DIVIDE([Rev], _maxLineSafe) * (_baseY - _topY)
			        RETURN FORMAT(_x, "0") & "," & FORMAT(_y, "0"),
			        " ", [MesNum], ASC)
			VAR _line_dots =
			    CONCATENATEX(_tbl,
			        VAR _x = _xLeft + ([MesNum] - 1) * _step + _step/2
			        VAR _y = _baseY - DIVIDE([Rev], _maxLineSafe) * (_baseY - _topY)
			        VAR _vlbl = SWITCH(TRUE(),
			            [Rev] >= 1000000, "R$" & FORMAT([Rev]/1000000, "0.0") & "M",
			            [Rev] >= 1000, "R$" & FORMAT([Rev]/1000, "0") & "K",
			            "")
			        RETURN
			        "<circle cx='" & FORMAT(_x, "0") & "' cy='" & FORMAT(_y, "0") & "' r='5' fill='#22c55e' stroke='#0D1117' stroke-width='2'/>" &
			        IF([Rev] > 0, "<text x='" & FORMAT(_x, "0") & "' y='" & FORMAT(_y - 10, "0") & "' text-anchor='middle' font-size='10' font-weight='bold' fill='#22c55e'>" & _vlbl & "</text>", ""),
			        "", [MesNum], ASC)
			VAR _eixoY =
			    "<text x='55' y='" & FORMAT(_topY + 4, "0") & "' text-anchor='end' font-size='10' fill='#94A3B8'>" & SWITCH(TRUE(), _maxBar >= 1000000, FORMAT(_maxBar/1000000, "0.0") & "M", FORMAT(_maxBar/1000, "0") & "K") & "</text>" &
			    "<text x='55' y='" & FORMAT((_topY + _baseY)/2 + 4, "0") & "' text-anchor='end' font-size='10' fill='#94A3B8'>" & SWITCH(TRUE(), _maxBar >= 1000000, FORMAT(_maxBar/2000000, "0.0") & "M", FORMAT(_maxBar/2000, "0") & "K") & "</text>" &
			    "<text x='55' y='" & FORMAT(_baseY + 4, "0") & "' text-anchor='end' font-size='10' fill='#94A3B8'>0</text>"
			RETURN
			"<svg width='100%' height='" & _h & "' viewBox='0 0 " & _w & " " & _h & "' preserveAspectRatio='xMidYMid meet' xmlns='http://www.w3.org/2000/svg'>" &
			"<line x1='58' y1='" & FORMAT(_topY, "0") & "' x2='" & FORMAT(_w - 10, "0") & "' y2='" & FORMAT(_topY, "0") & "' stroke='#1F2937' stroke-width='1' stroke-dasharray='2,2'/>" &
			"<line x1='58' y1='" & FORMAT((_topY + _baseY)/2, "0") & "' x2='" & FORMAT(_w - 10, "0") & "' y2='" & FORMAT((_topY + _baseY)/2, "0") & "' stroke='#1F2937' stroke-width='1' stroke-dasharray='2,2'/>" &
			"<line x1='58' y1='" & FORMAT(_baseY, "0") & "' x2='" & FORMAT(_w - 10, "0") & "' y2='" & FORMAT(_baseY, "0") & "' stroke='#94A3B8' stroke-width='1.5'/>" &
			_eixoY &
			_bars &
			"<polyline points='" & _line_pts & "' fill='none' stroke='#22c55e' stroke-width='2.5' stroke-linejoin='round'/>" &
			_line_dots &
			"</svg>"
		displayFolder: HTML Dashboard\SVG
		lineageTag: 12345678-1111-2222-3333-BIGSPNDREV01

	/// ═══════════════════════════════════════════════════════════
	/// DONUT MIX CANAL V9 grande
	/// ═══════════════════════════════════════════════════════════
	measure '_HTML Donut Canal V9' =
			VAR _meta = [Meta Investimento Total]
			VAR _ga = [GA Investimento]
			VAR _tot = _meta + _ga
			VAR _pctMeta = DIVIDE(_meta, _tot)
			VAR _pctGA = DIVIDE(_ga, _tot)
			VAR _ang = _pctMeta * 360
			VAR _rad = (_ang - 90) * PI() / 180
			VAR _cx = 95
			VAR _cy = 95
			VAR _r = 75
			VAR _x = _cx + _r * COS(_rad)
			VAR _y = _cy + _r * SIN(_rad)
			VAR _largeArc = IF(_ang > 180, 1, 0)
			RETURN
			"<svg width='190' height='190' viewBox='0 0 190 190' xmlns='http://www.w3.org/2000/svg' style='display:block;margin:0 auto;'>" &
			"<circle cx='95' cy='95' r='75' fill='none' stroke='#4285F4' stroke-width='32'/>" &
			"<path d='M 95 20 A 75 75 0 " & _largeArc & " 1 " & FORMAT(_x,"0.0") & " " & FORMAT(_y,"0.0") & " L 95 95 Z' fill='#1877F2'/>" &
			"<circle cx='95' cy='95' r='52' fill='#161B22'/>" &
			"<text x='95' y='90' text-anchor='middle' fill='#fff' font-size='22' font-weight='bold'>R$" & FORMAT(_tot/1000, "#,##0") & "K</text>" &
			"<text x='95' y='108' text-anchor='middle' fill='#94A3B8' font-size='10'>Total invest</text>" &
			"</svg>" &
			"<div style='display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:8px;font-family:Segoe UI;'>" &
			"<div style='background:#1F2937;border-left:3px solid #1877F2;padding:6px 10px;border-radius:4px;'><div style='color:#1877F2;font-size:9px;font-weight:bold;'>META</div><div style='color:#fff;font-size:14px;font-weight:bold;'>" & FORMAT(_pctMeta, "0%") & "</div><div style='color:#94A3B8;font-size:10px;'>R$ " & FORMAT(_meta/1000, "#,##0") & "K</div></div>" &
			"<div style='background:#1F2937;border-left:3px solid #4285F4;padding:6px 10px;border-radius:4px;'><div style='color:#4285F4;font-size:9px;font-weight:bold;'>GOOGLE</div><div style='color:#fff;font-size:14px;font-weight:bold;'>" & FORMAT(_pctGA, "0%") & "</div><div style='color:#94A3B8;font-size:10px;'>R$ " & FORMAT(_ga/1000, "#,##0") & "K</div></div>" &
			"</div>"
		displayFolder: HTML Dashboard\Componentes
		lineageTag: 12345678-1111-2222-3333-DONUTV900001

	/// ═══════════════════════════════════════════════════════════
	/// MINI-FUNIL HORIZONTAL V10 — compacto com taxas
	/// ═══════════════════════════════════════════════════════════
	measure '_HTML Mini Funil V10' =
			VAR _imp = [Total Impressões Ads]
			VAR _cli = [Total Cliques Ads]
			VAR _conv = [Total Conversões Ads]
			VAR _ctr = DIVIDE(_cli, _imp)
			VAR _cr = DIVIDE(_conv, _cli)
			RETURN
			"<div style='display:flex;align-items:center;gap:6px;font-family:Segoe UI;font-size:10px;'>" &
			"<div style='flex:1;text-align:center;background:#E05A00;color:#fff;padding:6px;border-radius:4px;'><div style='font-size:13px;font-weight:bold;'>" & [_Imp BR] & "</div><div style='font-size:8px;opacity:0.85;'>IMPRESSÕES</div></div>" &
			"<div style='color:#FBBF24;font-weight:bold;font-size:10px;'>→ " & FORMAT(_ctr, "0.0%") & "</div>" &
			"<div style='flex:1;text-align:center;background:#22d3ee;color:#0D1117;padding:6px;border-radius:4px;'><div style='font-size:13px;font-weight:bold;'>" & [_Cliques BR] & "</div><div style='font-size:8px;opacity:0.85;'>CLIQUES</div></div>" &
			"<div style='color:#FBBF24;font-weight:bold;font-size:10px;'>→ " & FORMAT(_cr, "0.0%") & "</div>" &
			"<div style='flex:1;text-align:center;background:#a78bfa;color:#fff;padding:6px;border-radius:4px;'><div style='font-size:13px;font-weight:bold;'>" & [_Conv BR] & "</div><div style='font-size:8px;opacity:0.85;'>CONVERSÕES</div></div>" &
			"<div style='color:#22c55e;font-weight:bold;font-size:10px;'>→ " & [_ROAS BR] & "</div>" &
			"<div style='flex:1;text-align:center;background:#22c55e;color:#fff;padding:6px;border-radius:4px;'><div style='font-size:13px;font-weight:bold;'>" & [_Receita BR] & "</div><div style='font-size:8px;opacity:0.85;'>RECEITA</div></div>" &
			"</div>"
		displayFolder: HTML Dashboard\Componentes
		lineageTag: aabbccdd-1111-2222-3333-FUNILV1000001

	/// ═══════════════════════════════════════════════════════════
	/// FORMATADAS GOOGLE ADS — strings BR para HTML
	/// ═══════════════════════════════════════════════════════════
	measure '_GA Invest BR' =
			VAR _v = [GA Investimento]
			RETURN SWITCH(TRUE(),
			    _v >= 1000000, "R$ " & FORMAT(_v/1000000, "0.00") & " Mi",
			    _v >= 1000, "R$ " & FORMAT(_v/1000, "0.0") & " Mil",
			    "R$ " & FORMAT(_v, "0.00"))
		displayFolder: HTML Dashboard\GA Formatadas
		lineageTag: gaaa0001-1111-2222-3333-INVBRAA00001

	measure '_GA Receita BR' =
			VAR _v = [GA Receita]
			RETURN SWITCH(TRUE(),
			    _v >= 1000000, "R$ " & FORMAT(_v/1000000, "0.00") & " Mi",
			    _v >= 1000, "R$ " & FORMAT(_v/1000, "0.0") & " Mil",
			    "R$ " & FORMAT(_v, "0.00"))
		displayFolder: HTML Dashboard\GA Formatadas
		lineageTag: gaaa0001-1111-2222-3333-RECBRAA00001

	measure '_GA Conv BR' = FORMAT([GA Conversões], "#,##0")
		displayFolder: HTML Dashboard\GA Formatadas
		lineageTag: gaaa0001-1111-2222-3333-CONVBRAA0001

	measure '_GA ROAS BR' =
			VAR _v = [GA ROAS]
			RETURN IF(_v > 0, FORMAT(_v, "0.00") & "x", "—")
		displayFolder: HTML Dashboard\GA Formatadas
		lineageTag: gaaa0001-1111-2222-3333-ROASBRAA0001

	measure '_GA Imp BR' =
			VAR _v = [GA Impressões]
			RETURN SWITCH(TRUE(),
			    _v >= 1000000, FORMAT(_v/1000000, "0.0") & " Mi",
			    _v >= 1000, FORMAT(_v/1000, "0") & " Mil",
			    FORMAT(_v, "0"))
		displayFolder: HTML Dashboard\GA Formatadas
		lineageTag: gaaa0001-1111-2222-3333-IMPBRAA00001

	measure '_GA Cliques BR' =
			VAR _v = [GA Cliques]
			RETURN SWITCH(TRUE(),
			    _v >= 1000000, FORMAT(_v/1000000, "0.0") & " Mi",
			    _v >= 1000, FORMAT(_v/1000, "0") & " Mil",
			    FORMAT(_v, "0"))
		displayFolder: HTML Dashboard\GA Formatadas
		lineageTag: gaaa0001-1111-2222-3333-CLKBRAA00001

	measure '_GA CPC BR' = "R$ " & FORMAT([GA CPC], "0.00")
