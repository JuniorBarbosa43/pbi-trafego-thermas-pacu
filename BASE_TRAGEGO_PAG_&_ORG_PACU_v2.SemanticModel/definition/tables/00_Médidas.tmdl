	/// Variação percentual MoM do investimento total em Ads.
	measure 'Investimento Ads ΔMoM' =
			VAR _atual = [Total Investimento Ads]
			VAR _anterior = [Investimento Ads Mês Anterior]
			RETURN DIVIDE(_atual - _anterior, _anterior)
		formatString: +0.0%;-0.0%;0.0%
