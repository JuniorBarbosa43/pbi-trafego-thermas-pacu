	/// Impressões Ads no ano anterior (mesmo período).
	measure 'Impressões Ads Ano Anterior' =
			VAR _anoMax = MAXX(ALLSELECTED('01_Calendário'), '01_Calendário'[Ano])
			RETURN
			CALCULATE(SUM(Meta_Ads_Campanhas[impressions]) + SUM(Google_Ads_Campanhas[impressions]), REMOVEFILTERS('01_Calendário'[Ano]), '01_Calendário'[Ano] = _anoMax - 1)
		formatString: #,##0
		displayFolder: Comparativos
		lineageTag: 7d3bb7bb-aa01-4c76-a3b9-0001000010af

	/// Total de conversões Ads (GA + Meta purchases). Filtrado pelo ano selecionado (ou ano corrente por padrão).
	measure 'Total Conversões Ads' =
			VAR _anos_sel = ALLSELECTED('01_Calendário'[Ano])
			VAR _ano = IF(COUNTROWS(_anos_sel) = 1, MINX(_anos_sel, '01_Calendário'[Ano]), YEAR(TODAY()))
			VAR _ga = CALCULATE(
			    0 + SUM(Google_Ads_Campanhas[conversions]),
			    KEEPFILTERS('01_Calendário'[Ano] = _ano)
			)
			VAR _meta = CALCULATE(
			    IF(ISBLANK(SUM(Meta_Ads_Campanhas[purchases])), 0, SUM(Meta_Ads_Campanhas[purchases])),
			    KEEPFILTERS('01_Calendário'[Ano] = _ano)
			)
			RETURN _ga + _meta
		formatString: #,##0
		displayFolder: Tráfego Pago Consolidado
		lineageTag: 7d3bb7bb-aa01-4c76-a3b9-0001000010b1

	/// Conversões Ads no ano anterior (GA + Meta Purchases).
	measure 'Conversões Ads Ano Anterior' =
			VAR _anoMax = MAXX(ALLSELECTED('01_Calendário'), '01_Calendário'[Ano])
			VAR _ga = CALCULATE(0 + SUM(Google_Ads_Campanhas[conversions]), REMOVEFILTERS('01_Calendário'[Ano]), '01_Calendário'[Ano] = _anoMax - 1)
			VAR _meta = CALCULATE(
			    IF(ISBLANK(SUM(Meta_Ads_Campanhas[purchases])), 0, SUM(Meta_Ads_Campanhas[purchases])),
			    REMOVEFILTERS('01_Calendário'[Ano]),
			    '01_Calendário'[Ano] = _anoMax - 1
			)
			RETURN _ga + _meta
		formatString: #,##0
		displayFolder: Comparativos
		lineageTag: 7d3bb7bb-aa01-4c76-a3b9-0001000010b2

	/// Variação percentual YoY das conversões.
	measure 'Conversões Ads ΔYoY' =
			VAR _anoMax = MAXX(ALLSELECTED('01_Calendário'), '01_Calendário'[Ano])
			VAR _gaAtual = CALCULATE(0 + SUM(Google_Ads_Campanhas[conversions]), REMOVEFILTERS('01_Calendário'[Ano]), '01_Calendário'[Ano] = _anoMax)
			VAR _metaAtual = CALCULATE(IF(ISBLANK(SUM(Meta_Ads_Campanhas[purchases])), 0, SUM(Meta_Ads_Campanhas[purchases])), REMOVEFILTERS('01_Calendário'[Ano]), '01_Calendário'[Ano] = _anoMax)
			VAR _atual = _gaAtual + _metaAtual
			VAR _anterior = [Conversões Ads Ano Anterior]
			RETURN DIVIDE(_atual - _anterior, _anterior)
		formatString: +0.0%;-0.0%;0.0%
		displayFolder: Comparativos
		lineageTag: 7d3bb7bb-aa01-4c76-a3b9-0001000010b3

	/// Custo por aquisição em Ads (custo / conversão). BLANK se não há conversões.
	measure 'CPA Ads' =
			VAR _conv = [Total Conversões Ads]
			RETURN IF(_conv > 0, DIVIDE([Total Investimento Ads], _conv), BLANK())
		formatString: R$ #,##0.00
		displayFolder: Tráfego Pago Consolidado\Custo
		lineageTag: 7d3bb7bb-aa01-4c76-a3b9-0001000010b4

	/// Receita estimada de conversões Google Ads.
	measure 'Receita Conversões Ads' =
			VAR _anos_sel = ALLSELECTED('01_Calendário'[Ano])
			VAR _ano = IF(COUNTROWS(_anos_sel) = 1, MINX(_anos_sel, '01_Calendário'[Ano]), YEAR(TODAY()))
			VAR _ga = CALCULATE(
			    0 + SUM(Google_Ads_Campanhas[conversions_value]),
			    KEEPFILTERS('01_Calendário'[Ano] = _ano)
			)
			VAR _meta = CALCULATE(
			    IF(ISBLANK(SUM(Meta_Ads_Campanhas[purchase_value])), 0, SUM(Meta_Ads_Campanhas[purchase_value])),
			    KEEPFILTERS('01_Calendário'[Ano] = _ano)
			)
			RETURN _ga + _meta
		formatString: R$ #,##0.00
		displayFolder: Tráfego Pago Consolidado\Retorno
		lineageTag: 7d3bb7bb-aa01-4c76-a3b9-0001000010b6

	/// ROAS direto Ads (receita conversão / investimento).
	measure 'ROAS Conversão Ads' =
			VAR _rec = [Receita Conversões Ads]
			VAR _inv = [Total Investimento Ads]
			RETURN IF(_rec > 0 && _inv > 0, DIVIDE(_rec, _inv), BLANK())
		formatString: 0.00"x"
		displayFolder: Tráfego Pago Consolidado\Retorno
		lineageTag: 7d3bb7bb-aa01-4c76-a3b9-0001000010b7

	/// Receita Google Ads. Filtrado pelo ano selecionado (ou ano corrente por padrão).
	measure 'GA Receita' =
