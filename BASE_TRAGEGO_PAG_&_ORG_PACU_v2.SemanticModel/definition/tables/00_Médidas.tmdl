	/// Alcance único formatado para cards (155 Mil / 2,3 Mi).
	measure '_FB Alcance BR' =
			VAR _v = [FB Alcance Único]
			RETURN
			SWITCH(TRUE(),
			    _v >= 1000000, FORMAT(_v/1000000, "0.0") & " Mi",
			    _v >= 1000, FORMAT(_v/1000, "0") & " Mil",
			    FORMAT(_v, "0")
			)
		displayFolder: Orgânico FB\Formatadas
