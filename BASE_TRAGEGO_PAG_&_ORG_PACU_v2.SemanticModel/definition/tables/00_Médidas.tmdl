	/// Crescimento líquido de seguidores IG no ano — último snapshot menos primeiro snapshot do ano.
	measure 'IG Crescimento Líquido' =
			VAR _anoMax = MAXX(ALLSELECTED('01_Calendário'), '01_Calendário'[Ano])
			VAR _ultimo  = CALCULATE(MAX(Meta_Organico_IG[valor]), Meta_Organico_IG[metrica] = "follower_count", REMOVEFILTERS('01_Calendário'), '01_Calendário'[Ano] = _anoMax)
			VAR _primeiro = CALCULATE(MIN(Meta_Organico_IG[valor]), Meta_Organico_IG[metrica] = "follower_count", REMOVEFILTERS('01_Calendário'), '01_Calendário'[Ano] = _anoMax)
			RETURN IF(ISBLANK(_ultimo) || ISBLANK(_primeiro), BLANK(), _ultimo - _primeiro)
		formatString: +#,##0;-#,##0;0
		displayFolder: Orgânico IG
		lineageTag: soc-igcresl-4c76-IG00000001

	/// YoY do crescimento líquido de seguidores IG.
	measure 'IG Crescimento ΔYoY' =
			VAR _anoMax = MAXX(ALLSELECTED('01_Calendário'), '01_Calendário'[Ano])
			VAR _cy = CALCULATE(MAX(Meta_Organico_IG[valor]), Meta_Organico_IG[metrica] = "follower_count", REMOVEFILTERS('01_Calendário'), '01_Calendário'[Ano] = _anoMax) - CALCULATE(MIN(Meta_Organico_IG[valor]), Meta_Organico_IG[metrica] = "follower_count", REMOVEFILTERS('01_Calendário'), '01_Calendário'[Ano] = _anoMax)
			VAR _ly = CALCULATE(MAX(Meta_Organico_IG[valor]), Meta_Organico_IG[metrica] = "follower_count", REMOVEFILTERS('01_Calendário'), '01_Calendário'[Ano] = _anoMax - 1) - CALCULATE(MIN(Meta_Organico_IG[valor]), Meta_Organico_IG[metrica] = "follower_count", REMOVEFILTERS('01_Calendário'), '01_Calendário'[Ano] = _anoMax - 1)
			RETURN IF(ABS(_ly) > 0, DIVIDE(_cy - _ly, ABS(_ly)), BLANK())
		formatString: +0.0%;-0.0%;0.0%
		displayFolder: Orgânico IG
		lineageTag: soc-igcresdyoy-4c76-IG00000002

