	/// FB Reações do ano anterior — para comparativo YoY mesmo período.
	measure 'FB Reações Ano Anterior' =
			VAR _anoMax = MAXX(ALLSELECTED('01_Calendário'), '01_Calendário'[Ano])
			VAR _mesMax = IF(_anoMax = YEAR(TODAY()), MONTH(TODAY()), 12)
			RETURN
			CALCULATE(
			    SUM(Meta_Organico_FB[valor]),
			    Meta_Organico_FB[metrica] = "page_actions_post_reactions_total",
			    REMOVEFILTERS('01_Calendário'[Ano]),
			    '01_Calendário'[Ano] = _anoMax - 1,
			    '01_Calendário'[MêsNúmero] <= _mesMax
			)
		formatString: #,##0
		displayFolder: Orgânico FB
		lineageTag: fb999001-aaaa-bbbb-cccc-000000000020

	measure 'FB Reações ΔYoY' =
			VAR _anoMax = MAXX(ALLSELECTED('01_Calendário'), '01_Calendário'[Ano])
			VAR _mesMax = IF(_anoMax = YEAR(TODAY()), MONTH(TODAY()), 12)
			VAR _cy = CALCULATE(SUM(Meta_Organico_FB[valor]), Meta_Organico_FB[metrica] = "page_actions_post_reactions_total", REMOVEFILTERS('01_Calendário'[Ano]), '01_Calendário'[Ano] = _anoMax)
			VAR _ly = CALCULATE(SUM(Meta_Organico_FB[valor]), Meta_Organico_FB[metrica] = "page_actions_post_reactions_total", REMOVEFILTERS('01_Calendário'[Ano]), '01_Calendário'[Ano] = _anoMax - 1, '01_Calendário'[MêsNúmero] <= _mesMax)
			RETURN IF(_ly > 0, DIVIDE(_cy - _ly, _ly), BLANK())
		formatString: +0.0%;-0.0%;0.0%
		displayFolder: Orgânico FB
		lineageTag: fb999001-aaaa-bbbb-cccc-000000000021

	/// Total de seguidores FB — último snapshot disponível, ignorando o slicer de período.
	measure 'FB Total Seguidores' =
