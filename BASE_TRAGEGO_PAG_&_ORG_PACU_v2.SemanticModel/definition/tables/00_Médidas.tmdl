	/// Investimento Google Ads. Default = ano corrente via SELECTEDVALUE quando slicer não filtrado.
	measure 'GA Investimento' =
			VAR _anos_sel = ALLSELECTED('01_Calendário'[Ano])
			VAR _ano = IF(COUNTROWS(_anos_sel) = 1, MINX(_anos_sel, '01_Calendário'[Ano]), YEAR(TODAY()))
			RETURN
			CALCULATE(
			    DIVIDE(SUM(Google_Ads_Campanhas[cost_micros]), 1000000),
			    KEEPFILTERS('01_Calendário'[Ano] = _ano)
			)
		formatString: R$ #,##0.00
		displayFolder: Google Ads
		lineageTag: f90b90f8-589d-4530-9bb5-37fade89cc34

	/// Impressões Google Ads. Filtrado pelo ano selecionado (ou ano corrente por padrão).
	measure 'GA Impressões' =
			VAR _anos_sel = ALLSELECTED('01_Calendário'[Ano])
			VAR _ano = IF(COUNTROWS(_anos_sel) = 1, MINX(_anos_sel, '01_Calendário'[Ano]), YEAR(TODAY()))
			RETURN
			CALCULATE(
