			VAR _ano = IF(COUNTROWS(_anos_sel) = 1, MINX(_anos_sel, '01_Calendário'[Ano]), YEAR(TODAY()))
			RETURN
			CALCULATE(
			    SUM(Google_Ads_Campanhas[conversions_value]),
			    KEEPFILTERS('01_Calendário'[Ano] = _ano)
			)
		formatString: R$ #,##0.00
		displayFolder: Google Ads\Retorno
		lineageTag: 7d3bb7bb-aa01-4c76-a3b9-GA0000000001

	/// ROAS Google Ads.
	measure 'GA ROAS' =
