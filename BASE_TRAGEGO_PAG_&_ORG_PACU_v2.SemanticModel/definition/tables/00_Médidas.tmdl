		lineageTag: 7d3bb7bb-aa01-4c76-a3b9-GA0000000004

	/// Variação YoY do investimento Google Ads.
	measure 'GA Investimento ΔYoY' =
			VAR _anoMax = MAXX(ALLSELECTED('01_Calendário'), '01_Calendário'[Ano])
			VAR _cy = CALCULATE([_GA Invest Bruto], REMOVEFILTERS('01_Calendário'[Ano]), '01_Calendário'[Ano] = _anoMax)
