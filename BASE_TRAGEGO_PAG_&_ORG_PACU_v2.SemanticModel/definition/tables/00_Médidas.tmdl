			RETURN IF(_rec > 0 && _inv > 0, DIVIDE(_rec, _inv), BLANK())
		formatString: 0.00"x"
		displayFolder: Google Ads\Retorno
		lineageTag: 7d3bb7bb-aa01-4c76-a3b9-GA0000000002

