			VAR _cy = CALCULATE(SUM(Meta_Organico_IG[valor]), Meta_Organico_IG[metrica] = "total_interactions", REMOVEFILTERS('01_Calendário'), '01_Calendário'[Ano] = _anoMax)
			VAR _ly = CALCULATE(SUM(Meta_Organico_IG[valor]), Meta_Organico_IG[metrica] = "total_interactions", REMOVEFILTERS('01_Calendário'), '01_Calendário'[Ano] = _anoMax - 1, '01_Calendário'[MêsNúmero] <= _mesMax)
