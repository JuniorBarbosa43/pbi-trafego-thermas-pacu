	/// Variação % de seguidores FB nos últimos 30 dias vs os 30 dias anteriores.
	measure 'FB Seg Δ30d' =
			VAR _ultimaData =
			    CALCULATE(
			        MAX(Meta_Organico_FB[DateKey]),
			        REMOVEFILTERS('01_Calendário'),
			        Meta_Organico_FB[metrica] = "page_followers_count"
			    )
			VAR _atual =
			    CALCULATE(
			        SUM(Meta_Organico_FB[valor]),
			        REMOVEFILTERS('01_Calendário'),
			        Meta_Organico_FB[metrica] = "page_followers_count",
			        Meta_Organico_FB[DateKey] = _ultimaData
			    )
			VAR _anterior =
			    CALCULATE(
			        SUM(Meta_Organico_FB[valor]),
			        REMOVEFILTERS('01_Calendário'),
			        Meta_Organico_FB[metrica] = "page_followers_count",
			        Meta_Organico_FB[DateKey] = _ultimaData - 30
			    )
			RETURN DIVIDE(_atual - _anterior, _anterior)
		formatString: +0.0%;-0.0%;0.0%
		displayFolder: Orgânico FB
		lineageTag: 5500aaaa-bbbb-cccc-dddd-FB0000000032

