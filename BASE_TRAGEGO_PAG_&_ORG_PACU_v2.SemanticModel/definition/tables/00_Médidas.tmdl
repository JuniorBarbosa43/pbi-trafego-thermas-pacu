	/// Investimento Google Ads no ano anterior (mesmo período).
	measure 'GA Invest Ano Anterior' =
			VAR _anoMax = MAXX(ALLSELECTED('01_Calendário'), '01_Calendário'[Ano])
			RETURN
			CALCULATE([_GA Invest Bruto], REMOVEFILTERS('01_Calendário'[Ano]), '01_Calendário'[Ano] = _anoMax - 1)
