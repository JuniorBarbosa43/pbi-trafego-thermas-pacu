	/// ═══════════════════════════════════════════════════════════
	/// CHART V1 GA — Spend vs Revenue 12 meses (largura inteira)
	/// ═══════════════════════════════════════════════════════════
	measure '_HTML GA Big Spend Revenue' =
			VAR _ano = MAX('01_Calendário'[Ano])
			VAR _tbl =
			    CALCULATETABLE(
			        ADDCOLUMNS(VALUES('01_Calendário'[Mês]),
			            "MesNum", CALCULATE(MAX('01_Calendário'[MêsNúmero])),
			            "Spend", COALESCE([GA Investimento], 0),
			            "Rev", COALESCE([GA Receita], 0),
			            "Roas", COALESCE([GA ROAS], 0)),
			        '01_Calendário'[Ano] = _ano
			    )
			VAR _maxBar = MAXX(_tbl, [Spend])
			VAR _maxLine = MAXX(_tbl, [Rev])
			VAR _maxBarSafe = IF(_maxBar <= 0, 1, _maxBar)
			VAR _maxLineSafe = IF(_maxLine <= 0, 1, _maxLine)
			VAR _w = 800
			VAR _h = 270
			VAR _xLeft = 60
			VAR _xRight = 60
			VAR _bw = 38
			VAR _step = (_w - _xLeft - _xRight) / 12
			VAR _baseY = 220
			VAR _topY = 30
			VAR _bars =
			    CONCATENATEX(_tbl,
			        VAR _x = _xLeft + ([MesNum] - 1) * _step + (_step - _bw) / 2
			        VAR _hSpend = MAX(0, DIVIDE([Spend], _maxBarSafe) * (_baseY - _topY))
			        VAR _y = _baseY - _hSpend
			        VAR _label = SWITCH(TRUE(),
			            [Spend] >= 1000000, "R$" & FORMAT([Spend]/1000000, "0.0") & "M",
			            [Spend] >= 1000, "R$" & FORMAT([Spend]/1000, "0") & "K",
			            "R$" & FORMAT([Spend], "0"))
			VAR _roasLbl = IF([Roas] > 0, FORMAT([Roas], "0.0") & "x", "")
			VAR _roasColor = SWITCH(TRUE(), [Roas] >= 5, "#22C55E", [Roas] >= 3, "#EAB308", [Roas] > 0, "#EF4444", "#8B949E")
			        RETURN
			        "<rect x='" & FORMAT(_x, "0") & "' y='" & FORMAT(_y, "0") & "' width='" & _bw & "' height='" & FORMAT(_hSpend, "0") & "' fill='#4285F4' rx='3'/>" &
			        IF(_hSpend > 22, "<text x='" & FORMAT(_x + _bw/2, "0") & "' y='" & FORMAT(_y + 14, "0") & "' text-anchor='middle' font-size='11' font-weight='bold' fill='#fff'>" & _label & "</text>", "<text x='" & FORMAT(_x + _bw/2, "0") & "' y='" & FORMAT(_y - 6, "0") & "' text-anchor='middle' font-size='10' fill='#BFDBFE' font-weight='bold'>" & _label & "</text>") &
			        "<text x='" & FORMAT(_x + _bw/2, "0") & "' y='" & FORMAT(_baseY + 16, "0") & "' text-anchor='middle' font-size='11' fill='#E6EDF3' font-weight='bold'>" & UPPER(LEFT('01_Calendário'[Mês], 3)) & "</text>" &
			        IF([Roas] > 0, "<text x='" & FORMAT(_x + _bw/2, "0") & "' y='" & FORMAT(_baseY + 30, "0") & "' text-anchor='middle' font-size='10' fill='" & _roasColor & "' font-weight='bold'>" & _roasLbl & "</text>", ""),
			        "", [MesNum], ASC)
			VAR _line_pts =
			    CONCATENATEX(_tbl,
			        VAR _x = _xLeft + ([MesNum] - 1) * _step + _step/2
			        VAR _y = _baseY - DIVIDE([Rev], _maxLineSafe) * (_baseY - _topY)
			        RETURN FORMAT(_x, "0") & "," & FORMAT(_y, "0"),
			        " ", [MesNum], ASC)
			VAR _line_dots =
			    CONCATENATEX(_tbl,
			        VAR _x = _xLeft + ([MesNum] - 1) * _step + _step/2
			        VAR _y = _baseY - DIVIDE([Rev], _maxLineSafe) * (_baseY - _topY)
			        VAR _vlbl = SWITCH(TRUE(),
			            [Rev] >= 1000000, "R$" & FORMAT([Rev]/1000000, "0.0") & "M",
			            [Rev] >= 1000, "R$" & FORMAT([Rev]/1000, "0") & "K",
			            "")
			        RETURN
			        "<circle cx='" & FORMAT(_x, "0") & "' cy='" & FORMAT(_y, "0") & "' r='5' fill='#22C55E' stroke='#0D1117' stroke-width='2'/>" &
			        IF([Rev] > 0, "<text x='" & FORMAT(_x, "0") & "' y='" & FORMAT(_y - 10, "0") & "' text-anchor='middle' font-size='10' font-weight='bold' fill='#22C55E'>" & _vlbl & "</text>", ""),
			        "", [MesNum], ASC)
			VAR _eixoY =
			    "<text x='55' y='" & FORMAT(_topY + 4, "0") & "' text-anchor='end' font-size='10' fill='#8B949E'>" & SWITCH(TRUE(), _maxBar >= 1000000, FORMAT(_maxBar/1000000, "0.0") & "M", FORMAT(_maxBar/1000, "0") & "K") & "</text>" &
			    "<text x='55' y='" & FORMAT((_topY + _baseY)/2 + 4, "0") & "' text-anchor='end' font-size='10' fill='#8B949E'>" & SWITCH(TRUE(), _maxBar >= 1000000, FORMAT(_maxBar/2000000, "0.0") & "M", FORMAT(_maxBar/2000, "0") & "K") & "</text>" &
			    "<text x='55' y='" & FORMAT(_baseY + 4, "0") & "' text-anchor='end' font-size='10' fill='#8B949E'>0</text>"
			RETURN
			IF(ISBLANK([GA Investimento]), "",
			"<svg width='100%' height='" & _h & "' viewBox='0 0 " & _w & " " & _h & "' preserveAspectRatio='xMidYMid meet' xmlns='http://www.w3.org/2000/svg'>" &
			"<line x1='58' y1='" & FORMAT(_topY, "0") & "' x2='" & FORMAT(_w - 10, "0") & "' y2='" & FORMAT(_topY, "0") & "' stroke='#30363D' stroke-width='1' stroke-dasharray='2,2'/>" &
			"<line x1='58' y1='" & FORMAT((_topY + _baseY)/2, "0") & "' x2='" & FORMAT(_w - 10, "0") & "' y2='" & FORMAT((_topY + _baseY)/2, "0") & "' stroke='#30363D' stroke-width='1' stroke-dasharray='2,2'/>" &
			"<line x1='58' y1='" & FORMAT(_baseY, "0") & "' x2='" & FORMAT(_w - 10, "0") & "' y2='" & FORMAT(_baseY, "0") & "' stroke='#8B949E' stroke-width='1.5'/>" &
			_eixoY &
			_bars &
			"<polyline points='" & _line_pts & "' fill='none' stroke='#22C55E' stroke-width='2.5' stroke-linejoin='round'/>" &
			_line_dots &
			"</svg>")
		displayFolder: HTML Dashboard\GA SVG
		lineageTag: gabb0001-1111-2222-3333-CHARTGA00001

	/// ═══════════════════════════════════════════════════════════
	/// DONUT GA — Status ENABLED vs PAUSED (% invest)
	/// ═══════════════════════════════════════════════════════════
	measure '_HTML GA Donut Status' =
			VAR _enabled = CALCULATE([GA Investimento], Google_Ads_Campanhas[campaign_status] = "ENABLED")
			VAR _paused = CALCULATE([GA Investimento], Google_Ads_Campanhas[campaign_status] = "PAUSED")
			VAR _tot = _enabled + _paused
			VAR _pctEn = DIVIDE(_enabled, _tot)
			VAR _pctPa = DIVIDE(_paused, _tot)
			VAR _ang = _pctEn * 360
			VAR _rad = (_ang - 90) * 3.14159265358979 / 180
			VAR _x = 95 + 75 * COS(_rad)
			VAR _y = 95 + 75 * SIN(_rad)
			VAR _largeArc = IF(_ang > 180, 1, 0)
			VAR _donutPath =
			    SWITCH(TRUE(),
			        _pctEn >= 0.999, "<circle cx='95' cy='95' r='75' fill='#22C55E'/>",
			        _pctEn <= 0.001, "<circle cx='95' cy='95' r='75' fill='#8B949E'/>",
			        "<circle cx='95' cy='95' r='75' fill='none' stroke='#8B949E' stroke-width='32'/>" &
			        "<path d='M 95 20 A 75 75 0 " & _largeArc & " 1 " & FORMAT(_x,"0.0") & " " & FORMAT(_y,"0.0") & " L 95 95 Z' fill='#22C55E'/>"
			    )
			RETURN
			IF(ISBLANK([GA Investimento]), "",
			"<svg width='190' height='190' viewBox='0 0 190 190' xmlns='http://www.w3.org/2000/svg' style='display:block;margin:0 auto;'>" &
			_donutPath &
			"<circle cx='95' cy='95' r='52' fill='#161B22'/>" &
			"<text x='95' y='90' text-anchor='middle' fill='#fff' font-size='20' font-weight='bold'>" & FORMAT(_pctEn, "0%") & "</text>" &
			"<text x='95' y='108' text-anchor='middle' fill='#8B949E' font-size='10'>ativas</text>" &
			"</svg>" &
			"<div style='display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:8px;font-family:Segoe UI;'>" &
			"<div style='background:#1C2128;border-left:3px solid #22C55E;padding:6px 10px;border-radius:4px;'><div style='color:#22C55E;font-size:9px;font-weight:bold;'>ENABLED</div><div style='color:#fff;font-size:14px;font-weight:bold;'>" & FORMAT(_pctEn, "0%") & "</div><div style='color:#8B949E;font-size:10px;'>R$ " & FORMAT(_enabled/1000, "#,##0") & "K</div></div>" &
			"<div style='background:#1C2128;border-left:3px solid #8B949E;padding:6px 10px;border-radius:4px;'><div style='color:#8B949E;font-size:9px;font-weight:bold;'>PAUSED</div><div style='color:#fff;font-size:14px;font-weight:bold;'>" & FORMAT(_pctPa, "0%") & "</div><div style='color:#8B949E;font-size:10px;'>R$ " & FORMAT(_paused/1000, "#,##0") & "K</div></div>" &
			"</div>")
		displayFolder: HTML Dashboard\GA Componentes
		lineageTag: gabb0002-1111-2222-3333-DONUTGA00001

	/// ═══════════════════════════════════════════════════════════
	/// MINI FUNIL GA horizontal
	/// ═══════════════════════════════════════════════════════════
	measure '_HTML GA Mini Funil' =
			VAR _imp = [GA Impressões]
			VAR _cli = [GA Cliques]
			VAR _conv = [GA Conversões]
			VAR _rec = [GA Receita]
			VAR _ctr = DIVIDE(_cli, _imp)
			VAR _cr = DIVIDE(_conv, _cli)
			RETURN
			IF(ISBLANK(_imp), "",
			"<div style='display:flex;align-items:center;gap:6px;font-family:Segoe UI;font-size:10px;'>" &
			"<div style='flex:1;text-align:center;background:#4285F4;color:#fff;padding:6px;border-radius:4px;'><div style='font-size:13px;font-weight:bold;'>" & [_GA Imp BR] & "</div><div style='font-size:8px;opacity:0.85;'>IMPRESSÕES</div></div>" &
			"<div style='color:#EAB308;font-weight:bold;font-size:10px;'>→ " & FORMAT(_ctr, "0.0%") & "</div>" &
			"<div style='flex:1;text-align:center;background:#06B6D4;color:#0D1117;padding:6px;border-radius:4px;'><div style='font-size:13px;font-weight:bold;'>" & [_GA Cliques BR] & "</div><div style='font-size:8px;opacity:0.85;'>CLIQUES</div></div>" &
			"<div style='color:#EAB308;font-weight:bold;font-size:10px;'>→ " & FORMAT(_cr, "0.0%") & "</div>" &
			"<div style='flex:1;text-align:center;background:#A855F7;color:#fff;padding:6px;border-radius:4px;'><div style='font-size:13px;font-weight:bold;'>" & [_GA Conv BR] & "</div><div style='font-size:8px;opacity:0.85;'>CONVERSÕES</div></div>" &
			"<div style='color:#22C55E;font-weight:bold;font-size:10px;'>→ " & [_GA ROAS BR] & "</div>" &
			"<div style='flex:1;text-align:center;background:#22C55E;color:#fff;padding:6px;border-radius:4px;'><div style='font-size:13px;font-weight:bold;'>" & [_GA Receita BR] & "</div><div style='font-size:8px;opacity:0.85;'>RECEITA</div></div>" &
			"</div>")
		displayFolder: HTML Dashboard\GA Componentes
		lineageTag: gabb0003-1111-2222-3333-FUNILGA00001

	/// SCORECARD DE EFICIÊNCIA — CPC × CPA × CPM
	measure _HTML_Scorecard_Eficiencia =
			VAR _ga_cpc   = [GA CPC]
			VAR _ga_cpm   = [GA CPM]
			VAR _ga_cpa   = [GA CPA]
			VAR _mc       = [Meta CPC]
			VAR _mm       = [Meta CPM]
			VAR _ma       = DIVIDE([Meta Investimento Total], [Total Conversões Ads])
			VAR _cc       = [CPC Consolidado]
			VAR _cm       = DIVIDE([Total Investimento Ads], [Total Impressões Ads]) * 1000
			VAR _ca       = [CPA Ads]
			VAR _p = "R$ "
			VAR _fga_cpc  = IF(_ga_cpc > 0, _p & FORMAT(_ga_cpc,  "#,##0.00"), "—")
			VAR _fga_cpm  = IF(_ga_cpm > 0, _p & FORMAT(_ga_cpm,  "#,##0.00"), "—")
			VAR _fga_cpa  = IF(_ga_cpa > 0, _p & FORMAT(_ga_cpa,  "#,##0.00"), "—")
			VAR _fmc      = IF(_mc    > 0, _p & FORMAT(_mc,        "#,##0.00"), "—")
			VAR _fmm      = IF(_mm    > 0, _p & FORMAT(_mm,        "#,##0.00"), "—")
			VAR _fma      = IF(_ma    > 0, _p & FORMAT(_ma,        "#,##0.00"), "—")
			VAR _fcc      = IF(_cc    > 0, _p & FORMAT(_cc,        "#,##0.00"), "—")
			VAR _fcm      = IF(_cm    > 0, _p & FORMAT(_cm,        "#,##0.00"), "—")
			VAR _fca      = IF(_ca    > 0, _p & FORMAT(_ca,        "#,##0.00"), "—")
			VAR _cgc = IF(_ga_cpc > 0 && _mc > 0, IF(_ga_cpc < _mc, "#22C55E", "#EF4444"), "#E6EDF3")
			VAR _cmc = IF(_ga_cpc > 0 && _mc > 0, IF(_mc < _ga_cpc, "#22C55E", "#EF4444"), "#E6EDF3")
			VAR _cga = IF(_ga_cpa > 0 && _ma > 0, IF(_ga_cpa < _ma, "#22C55E", "#EF4444"), "#E6EDF3")
			VAR _cma = IF(_ga_cpa > 0 && _ma > 0, IF(_ma < _ga_cpa, "#22C55E", "#EF4444"), "#E6EDF3")
			VAR _cgm = IF(_ga_cpm > 0 && _mm > 0, IF(_ga_cpm < _mm, "#22C55E", "#EF4444"), "#E6EDF3")
			VAR _cmm = IF(_ga_cpm > 0 && _mm > 0, IF(_mm < _ga_cpm, "#22C55E", "#EF4444"), "#E6EDF3")
			VAR _th = "style='font-size:10px;color:#8B949E;text-align:center;padding:4px 6px;border-bottom:1px solid #30363D;'"
			VAR _tdl = "style='font-size:10px;color:#8B949E;padding:4px 8px;font-weight:600;background:#0D1117;'"
			VAR _tdc = "style='font-size:13px;font-weight:700;text-align:center;padding:4px 6px;background:#161B22;'"
			VAR _tdo = "style='font-size:12px;font-weight:700;text-align:center;padding:4px 6px;background:#1a1200;color:#F97316;'"
			VAR _html =
			"<div style='background:#0D1117;font-family:Segoe UI,sans-serif;padding:6px 8px;box-sizing:border-box;width:100%;height:100%;'>" &
			"<div style='background:linear-gradient(90deg,#7C3AED,#4F46E5);padding:4px 10px;border-radius:4px;font-size:10px;font-weight:700;color:#fff;margin-bottom:5px;'>⚡ EFICIÊNCIA — CPC · CPA · CPM por canal</div>" &
			"<table style='width:100%;border-collapse:collapse;'>" &
			"<tr>" &
			  "<th style='font-size:10px;color:#8B949E;text-align:left;padding:4px 8px;border-bottom:1px solid #30363D;width:60px;'>Métrica</th>" &
			  "<th " & _th & " style='background:#1e3a8a;color:#93C5FD;font-size:10px;padding:4px 6px;text-align:center;border-bottom:1px solid #30363D;'>🅖 Google Ads</th>" &
			  "<th " & _th & " style='background:#5b21b6;color:#C4B5FD;font-size:10px;padding:4px 6px;text-align:center;border-bottom:1px solid #30363D;'>🅕 Meta Ads</th>" &
			  "<th " & _th & " style='background:#7c2d12;color:#FED7AA;font-size:10px;padding:4px 6px;text-align:center;border-bottom:1px solid #30363D;'>⊕ Consolidado</th>" &
			"</tr>" &
			"<tr>" &
			  "<td " & _tdl & ">CPC</td>" &
			  "<td " & _tdc & " style='font-size:13px;font-weight:700;text-align:center;padding:4px 6px;background:#161B22;color:" & _cgc & ";'>" & _fga_cpc & "</td>" &
			  "<td " & _tdc & " style='font-size:13px;font-weight:700;text-align:center;padding:4px 6px;background:#161B22;color:" & _cmc & ";'>" & _fmc & "</td>" &
			  "<td " & _tdo & ">" & _fcc & "</td>" &
			"</tr>" &
			"<tr>" &
			  "<td " & _tdl & ">CPA</td>" &
			  "<td " & _tdc & " style='font-size:13px;font-weight:700;text-align:center;padding:4px 6px;background:#161B22;color:" & _cga & ";'>" & _fga_cpa & "</td>" &
			  "<td " & _tdc & " style='font-size:13px;font-weight:700;text-align:center;padding:4px 6px;background:#161B22;color:" & _cma & ";'>" & _fma & "</td>" &
			  "<td " & _tdo & ">" & _fca & "</td>" &
			"</tr>" &
			"<tr>" &
			  "<td " & _tdl & ">CPM</td>" &
			  "<td " & _tdc & " style='font-size:13px;font-weight:700;text-align:center;padding:4px 6px;background:#161B22;color:" & _cgm & ";'>" & _fga_cpm & "</td>" &
			  "<td " & _tdc & " style='font-size:13px;font-weight:700;text-align:center;padding:4px 6px;background:#161B22;color:" & _cmm & ";'>" & _fmm & "</td>" &
			  "<td " & _tdo & ">" & _fcm & "</td>" &
			"</tr>" &
			"</table>" &
			"<div style='font-size:8px;color:#374151;text-align:right;margin-top:3px;'>🟢 melhor · 🔴 pior vs canal</div>" &
			"</div>"
			RETURN _html
		displayFolder: HTML Dashboard\TP V2 Bottom
		lineageTag: scef0001-1111-2222-3333-SCORECARD001

	/// TOP CAMPANHAS META — Barras Horizontais (Spend + CTR)
	measure _HTML_Top_Campanhas_Meta =
			VAR _dados = TOPN(9,
			    ADDCOLUMNS(
			        VALUES(Meta_Ads_Campanhas[campaign_name]),
			        "@sp", CALCULATE(SUM(Meta_Ads_Campanhas[spend])),
			        "@ct", CALCULATE(AVERAGE(Meta_Ads_Campanhas[ctr]))
			    ),
			    [@sp], DESC)
			VAR _tot  = SUMX(_dados, [@sp])
			VAR _mxsp = MAXX(_dados, [@sp])
			VAR _n    = COUNTROWS(_dados)
			VAR _W = 580  VAR _rh = 17  VAR _pad = 20
			VAR _H = _pad + _n * _rh + 2
			VAR _lw = 170  VAR _bmax = 290  VAR _cx = 472
			VAR _rows = CONCATENATEX(_dados,
			    VAR _rk = RANKX(_dados, [@sp], , DESC, Dense)
			    VAR _y  = _pad + (_rk - 1) * _rh
			    VAR _bw = MAX(2, DIVIDE([@sp], _mxsp) * _bmax)
			    VAR _co = IF(_rk = 1, "#F97316", IF(_rk <= 3, "#FB923C", "#6B7280"))
			    VAR _sf = IF([@sp] >= 1000, "R$ " & FORMAT([@sp]/1000,"#,##0.0") & "K", "R$ " & FORMAT([@sp],"#,##0"))
			    VAR _pf = FORMAT(DIVIDE([@sp], _tot), "0%")
			    VAR _tf = FORMAT([@ct]/100, "0.00%")
			    VAR _nm = LEFT(Meta_Ads_Campanhas[campaign_name], 24)
			    RETURN
			    "<text x='2' y='" & FORMAT(_y+11,"0") & "' font-size='8' fill='#8B949E' font-family='Segoe UI'>" & _nm & "</text>" &
			    "<rect x='" & FORMAT(_lw,"0") & "' y='" & FORMAT(_y+2,"0") & "' width='" & FORMAT(_bw,"0.0") & "' height='12' fill='" & _co & "' rx='2'/>" &
			    "<text x='" & FORMAT(_lw+_bw+2,"0.0") & "' y='" & FORMAT(_y+11,"0") & "' font-size='8' fill='#E6EDF3' font-family='Segoe UI'>" & _sf & " (" & _pf & ")</text>" &
			    "<text x='" & FORMAT(_cx,"0") & "' y='" & FORMAT(_y+11,"0") & "' font-size='8' fill='#3B82F6' font-family='Segoe UI'>" & _tf & "</text>",
			    "", [@sp], DESC)
			VAR _svg =
			    "<svg xmlns='http://www.w3.org/2000/svg' width='100%' viewBox='0 0 " & FORMAT(_W,"0") & " " & FORMAT(_H,"0") & "'>" &
			    "<rect width='" & FORMAT(_W,"0") & "' height='" & FORMAT(_H,"0") & "' fill='#161B22' rx='4'/>" &
			    "<text x='" & FORMAT(_lw,"0") & "' y='13' font-size='9' fill='#F97316' font-weight='700' font-family='Segoe UI'>SPEND</text>" &
			    "<text x='" & FORMAT(_cx,"0") & "' y='13' font-size='9' fill='#3B82F6' font-weight='700' font-family='Segoe UI'>CTR</text>" &
			    _rows & "</svg>"
			RETURN IF(_mxsp = 0 || ISBLANK(_mxsp), "", _svg)
		displayFolder: HTML Dashboard\TP V2 Bottom
		lineageTag: topc0001-1111-2222-3333-METACAMP001

	/// ROAS SEMANAL — Linha de Tendência por Semana
	measure _HTML_ROAS_Semanal =
			VAR _base = ADDCOLUMNS(
			    VALUES('01_Calendário'[SemanaDoAno]),
			    "@lbl",    CALCULATE(MAX('01_Calendário'[Semana Label])),
			    "@roas",   CALCULATE([ROAS Conversão Ads]),
			    "@invest", CALCULATE([Total Investimento Ads])
			)
			VAR _d = TOPN(26, FILTER(_base, [@invest] > 0), '01_Calendário'[SemanaDoAno], ASC)
			VAR _n = COUNTROWS(_d)
			VAR _mx = MAXX(_d, [@roas]) * 1.2
			VAR _W = 550  VAR _H = 62
			VAR _ml = 24  VAR _mr = 6  VAR _mt = 6  VAR _mb = 14
			VAR _pw = _W - _ml - _mr
			VAR _ph = _H - _mt - _mb
			VAR _ns = MAX(1, _n - 1)
			VAR _pts = CONCATENATEX(_d,
			    VAR _i = RANKX(_d, '01_Calendário'[SemanaDoAno], , ASC, Dense) - 1
			    VAR _cx = _ml + DIVIDE(_i, _ns) * _pw
			    VAR _cy = _mt + _ph - MAX(0, DIVIDE([@roas], _mx) * _ph)
			    RETURN FORMAT(_cx,"0.0") & "," & FORMAT(_cy,"0.0"),
			    " ", '01_Calendário'[SemanaDoAno], ASC)
			VAR _dots = CONCATENATEX(_d,
			    VAR _j  = RANKX(_d, '01_Calendário'[SemanaDoAno], , ASC, Dense) - 1
			    VAR _cx = _ml + DIVIDE(_j, _ns) * _pw
			    VAR _cy = _mt + _ph - MAX(0, DIVIDE([@roas], _mx) * _ph)
			    VAR _rv = [@roas]
			    VAR _co = IF(_rv >= 5, "#22C55E", IF(_rv >= 3, "#EAB308", "#EF4444"))
			    VAR _lb = [@lbl]
			    RETURN
			    "<circle cx='" & FORMAT(_cx,"0.0") & "' cy='" & FORMAT(_cy,"0.0") & "' r='2.5' fill='" & _co & "'/>" &
			    IF(_j = 0 || _j = _ns,
			        "<text x='" & FORMAT(_cx,"0.0") & "' y='" & FORMAT(_H-1,"0") & "' text-anchor='middle' font-size='7' fill='#6B7280'>" & _lb & "</text>" &
			        "<text x='" & FORMAT(_cx,"0.0") & "' y='" & FORMAT(_cy-3,"0.0") & "' text-anchor='middle' font-size='8' fill='" & _co & "' font-weight='600'>" & FORMAT(_rv,"0.0") & "x</text>",
			        ""),
			    "", '01_Calendário'[SemanaDoAno], ASC)
			VAR _r3y = IF(_mx > 0, _mt + _ph - MAX(0, DIVIDE(3, _mx) * _ph), _mt)
			VAR _r3  = IF(_mx >= 3,
			    "<line x1='" & FORMAT(_ml,"0") & "' y1='" & FORMAT(_r3y,"0.0") & "' x2='" & FORMAT(_ml+_pw,"0") & "' y2='" & FORMAT(_r3y,"0.0") & "' stroke='#EAB308' stroke-width='1' stroke-dasharray='3,2' opacity='0.5'/>" &
			    "<text x='" & FORMAT(_ml-1,"0") & "' y='" & FORMAT(_r3y+3,"0.0") & "' text-anchor='end' font-size='7' fill='#EAB308'>3x</text>", "")
			VAR _svg =
			    "<svg xmlns='http://www.w3.org/2000/svg' width='100%' viewBox='0 0 " & FORMAT(_W,"0") & " " & FORMAT(_H,"0") & "'>" &
			    "<rect width='" & FORMAT(_W,"0") & "' height='" & FORMAT(_H,"0") & "' fill='#161B22' rx='4'/>" &
			    "<line x1='" & FORMAT(_ml,"0") & "' y1='" & FORMAT(_mt,"0") & "' x2='" & FORMAT(_ml,"0") & "' y2='" & FORMAT(_mt+_ph,"0") & "' stroke='#30363D' stroke-width='1'/>" &
			    "<line x1='" & FORMAT(_ml,"0") & "' y1='" & FORMAT(_mt+_ph,"0") & "' x2='" & FORMAT(_ml+_pw,"0") & "' y2='" & FORMAT(_mt+_ph,"0") & "' stroke='#30363D' stroke-width='1'/>" &
			    "<text x='" & FORMAT(_ml-1,"0") & "' y='" & FORMAT(_mt+5,"0") & "' text-anchor='end' font-size='7' fill='#4B5563'>" & FORMAT(_mx,"0.0") & "x</text>" &
			    _r3 &
			    "<polyline points='" & _pts & "' fill='none' stroke='#3B82F6' stroke-width='2' stroke-linejoin='round'/>" &
			    _dots & "</svg>"
			RETURN IF(ISBLANK(_mx) || _mx = 0 || _n = 0, "", _svg)
		displayFolder: HTML Dashboard\TP V2 Bottom
		lineageTag: roas0001-1111-2222-3333-ROASSEM001

	/// ROAS Conversão Ads no ano anterior (mesmo período).
	measure 'ROAS Ads Ano Anterior' =
			VAR _anoMax = MAXX(ALLSELECTED('01_Calendário'), '01_Calendário'[Ano])
			VAR _rec_ga = CALCULATE(
			    0 + SUM(Google_Ads_Campanhas[conversions_value]),
			    REMOVEFILTERS('01_Calendário'[Ano]),
			    '01_Calendário'[Ano] = _anoMax - 1
			)
			VAR _rec_meta = CALCULATE(
			    IF(ISBLANK(SUM(Meta_Ads_Campanhas[purchase_value])), 0, SUM(Meta_Ads_Campanhas[purchase_value])),
			    REMOVEFILTERS('01_Calendário'[Ano]),
			    '01_Calendário'[Ano] = _anoMax - 1
			)
			VAR _rec = _rec_ga + _rec_meta
			VAR _inv_ga = CALCULATE(
			    DIVIDE(SUM(Google_Ads_Campanhas[cost_micros]), 1000000),
			    REMOVEFILTERS('01_Calendário'[Ano]),
			    '01_Calendário'[Ano] = _anoMax - 1
			)
			VAR _inv_meta = CALCULATE(
			    SUM(Meta_Ads_Campanhas[spend]),
			    REMOVEFILTERS('01_Calendário'[Ano]),
			    '01_Calendário'[Ano] = _anoMax - 1
			)
			VAR _inv = _inv_ga + _inv_meta
			RETURN IF(_rec > 0 && _inv > 0, DIVIDE(_rec, _inv), BLANK())
		formatString: 0.00"x"
		displayFolder: Tráfego Pago Consolidado\Retorno
		lineageTag: roas-conv-aa01-4c76-a3b9-000200001111

	/// Delta YoY do ROAS Conversão Ads.
	measure 'ROAS Ads ΔYoY' =
			VAR _anoMax = MAXX(ALLSELECTED('01_Calendário'), '01_Calendário'[Ano])
			VAR _rec_ga = CALCULATE(
			    0 + SUM(Google_Ads_Campanhas[conversions_value]),
			    REMOVEFILTERS('01_Calendário'[Ano]),
			    '01_Calendário'[Ano] = _anoMax
			)
			VAR _rec_meta = CALCULATE(
			    IF(ISBLANK(SUM(Meta_Ads_Campanhas[purchase_value])), 0, SUM(Meta_Ads_Campanhas[purchase_value])),
			    REMOVEFILTERS('01_Calendário'[Ano]),
			    '01_Calendário'[Ano] = _anoMax
			)
			VAR _rec = _rec_ga + _rec_meta
			VAR _inv_ga = CALCULATE(
			    DIVIDE(SUM(Google_Ads_Campanhas[cost_micros]), 1000000),
			    REMOVEFILTERS('01_Calendário'[Ano]),
			    '01_Calendário'[Ano] = _anoMax
			)
			VAR _inv_meta = CALCULATE(
			    SUM(Meta_Ads_Campanhas[spend]),
			    REMOVEFILTERS('01_Calendário'[Ano]),
			    '01_Calendário'[Ano] = _anoMax
			)
			VAR _cy = IF(_rec > 0 && _inv_ga + _inv_meta > 0, DIVIDE(_rec, _inv_ga + _inv_meta), BLANK())
			VAR _ly = [ROAS Ads Ano Anterior]
			RETURN IF(_ly > 0, DIVIDE(_cy - _ly, _ly), BLANK())
		formatString: +0.0%;-0.0%;0.0%
		displayFolder: Tráfego Pago Consolidado\Retorno
		lineageTag: roas-conv-bb02-4c76-a3b9-000200002222

