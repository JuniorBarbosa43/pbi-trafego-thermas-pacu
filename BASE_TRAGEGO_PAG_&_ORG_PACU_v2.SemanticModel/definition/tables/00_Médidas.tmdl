			VAR _ly = CALCULATE(SUM(Meta_Organico_IG[valor]), Meta_Organico_IG[metrica] = "accounts_engaged", REMOVEFILTERS('01_Calendário'), '01_Calendário'[Ano] = _anoMax - 1, '01_Calendário'[MêsNúmero] <= _mesMax)
