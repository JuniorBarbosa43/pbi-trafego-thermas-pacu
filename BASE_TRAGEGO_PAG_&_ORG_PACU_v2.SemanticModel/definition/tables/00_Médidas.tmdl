	/// FB Views Página do ano anterior — para comparativo YoY mesmo período.
	measure 'FB Views Página Ano Anterior' =
			VAR _anoMax = MAXX(ALLSELECTED('01_Calendário'), '01_Calendário'[Ano])
			VAR _mesMax = IF(_anoMax = YEAR(TODAY()), MONTH(TODAY()), 12)
			RETURN
			CALCULATE(
