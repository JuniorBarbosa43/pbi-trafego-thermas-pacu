	/// CTR ponderado (cliques/impressões*100) das campanhas Meta Ads. Filtrado via medidas base que já aplicam o ano corrente.
	measure 'Meta CTR Médio' = DIVIDE([Meta Cliques], [Meta Impressões]) * 100
		formatString: 0.00"%"
