	/// GA ROAS no ano máximo selecionado — para gráfico semanal sem mix de anos.
	measure 'Chart GA ROAS' =
			VAR _anoMax = MAXX(ALLSELECTED('01_Calendário'), '01_Calendário'[Ano])
			VAR _inv = CALCULATE([_GA Invest Bruto], REMOVEFILTERS('01_Calendário'[Ano]), '01_Calendário'[Ano] = _anoMax)
			VAR _rec = CALCULATE(SUM(Google_Ads_Campanhas[conversions_value]), REMOVEFILTERS('01_Calendário'[Ano]), '01_Calendário'[Ano] = _anoMax)
			RETURN IF(_inv > 0 && _rec > 0, DIVIDE(_rec, _inv), BLANK())
		formatString: 0.00"x"
		displayFolder: Gráficos
		lineageTag: chart-garoas01-4c76-a3b9-000900001111

