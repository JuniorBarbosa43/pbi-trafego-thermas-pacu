	/// Investimento total consolidado Meta + Google. Usa as medidas base que já filtram pelo ano mais recente.
	measure 'Total Investimento Ads' = [Meta Investimento Total] + [GA Investimento]
		formatString: R$ #,##0.00
		displayFolder: Tráfego Pago Consolidado
		lineageTag: 981e2330-d732-44a9-bd96-7ecb9d94ce63

	/// Cliques totais consolidados de todas as plataformas de ads.
	measure 'Total Cliques Ads' = 0 + [Meta Cliques] + [GA Cliques]
		formatString: #,##0
		displayFolder: Tráfego Pago Consolidado
		lineageTag: d0960846-cad0-4074-a1d0-1ce67d66c521

	/// Impressões totais consolidadas Meta + Google.
	measure 'Total Impressões Ads' = 0 + [Meta Impressões] + [GA Impressões]
		formatString: #,##0
		displayFolder: Tráfego Pago Consolidado
		lineageTag: 3e031f73-b888-4eec-a7c7-1ab0652aea30

	/// CTR médio geral consolidado (cliques / impressões) de todas as plataformas.
	measure 'CTR Consolidado' = DIVIDE(0 + [Meta Cliques] + [GA Cliques], 0 + [Meta Impressões] + [GA Impressões])
		formatString: 0.00%
		displayFolder: Tráfego Pago Consolidado
		lineageTag: 2340b829-241b-45dd-be85-06691a1bc038

	/// Custo por clique médio geral (investimento total / cliques totais).
	measure 'CPC Consolidado' = DIVIDE([Total Investimento Ads], [Total Cliques Ads])
		formatString: R$ #,##0.00
		displayFolder: Tráfego Pago Consolidado\Custo
		lineageTag: 37f5cdc9-0a16-4273-abb5-2c8866345dd8

	/// ROAS geral (Receita Limber / Investimento total Ads). Retorna 0 enquanto [Receita Limber] for placeholder.
	measure ROAS =
			VAR _receita = [Receita Limber]
			VAR _investimento = [Total Investimento Ads]
			RETURN
			    IF(
			        _receita > 0 && _investimento > 0,
			        DIVIDE(_receita, _investimento),
			        0
			    )
		formatString: 0.00"x"
		displayFolder: Tráfego Pago Consolidado\Retorno
		lineageTag: f2eccd7a-ab49-4896-9fda-780cc4f67f81

	/// Custo total de marketing (Ads). Filtra automaticamente pelo ano mais recente.
	measure 'Custo Total Marketing' = [Total Investimento Ads]
		formatString: R$ #,##0.00
		displayFolder: Tráfego Pago Consolidado\Custo
		lineageTag: 12c0b60f-c043-4bfb-bd17-0cf130e242bc

	/// Custo de aquisição por venda (ingresso). Usa Pedidos Confirmados com filtro de ano.
	measure 'CAC (Custo por Venda)' =
			VAR _custo = [Total Investimento Ads]
			VAR _vendas = [Pedidos Confirmados]
			RETURN
			    IF(_vendas > 0, DIVIDE(_custo, _vendas), BLANK())
		formatString: R$ #,##0.00
		displayFolder: Tráfego Pago Consolidado\Custo
		lineageTag: e3248159-b5e4-4bb0-a607-d8bfcd8313d2

	/// Retorno líquido sobre investimento total em marketing. Retorna 0 enquanto [Receita Limber] for placeholder.
	measure 'ROAS Líquido' =
			VAR _receita = [Receita Limber]
			VAR _custoTotal = [Custo Total Marketing]
			RETURN
			    IF(
			        _receita > 0 && _custoTotal > 0,
			        DIVIDE(_receita - _custoTotal, _custoTotal),
			        0
			    )
		formatString: 0.00"x"
		displayFolder: Tráfego Pago Consolidado\Retorno
		lineageTag: c52c1be2-8672-471e-ac6b-c7aba10b5d69

	/// Investimento Ads no mesmo período do ano anterior. Usa o ano base (atual ou selecionado) menos 1.
	measure 'Invest Ads Ano Ant' =
			VAR _anoMax = MAXX(ALLSELECTED('01_Calendário'), '01_Calendário'[Ano])
			RETURN
			CALCULATE([_Total Invest Bruto], REMOVEFILTERS('01_Calendário'[Ano]), '01_Calendário'[Ano] = _anoMax - 1)
		formatString: R$ #,##0.00
		displayFolder: Comparativos
		lineageTag: 50b0ca63-5f28-4c29-b6f7-a216333dffdd

	/// Variação percentual YoY do investimento total em Ads.
	measure 'Investimento Ads ΔYoY' =
			VAR _anoMax = MAXX(ALLSELECTED('01_Calendário'), '01_Calendário'[Ano])
			VAR _atual = CALCULATE([_Total Invest Bruto], REMOVEFILTERS('01_Calendário'[Ano]), '01_Calendário'[Ano] = _anoMax)
			VAR _anterior = [Invest Ads Ano Ant]
			RETURN DIVIDE(_atual - _anterior, _anterior)
		formatString: +0.0%;-0.0%;0.0%
		displayFolder: Comparativos
		lineageTag: 7d3bb7bb-83c7-4c76-a3b9-5719304325f4

	/// Temperatura média no período selecionado (°C). Apenas histórico.
	/// SELECTEDVALUE: usa o ano selecionado no slicer; default = ano corrente quando slicer em "tudo selecionado".
	measure 'Clima Temp Média' =
			VAR _anos_sel = ALLSELECTED('01_Calendário'[Ano])
			VAR _ano = IF(COUNTROWS(_anos_sel) = 1, MINX(_anos_sel, '01_Calendário'[Ano]), YEAR(TODAY()))
			VAR _meses = VALUES('01_Calendário'[MêsNúmero])
			RETURN
			CALCULATE(
			    AVERAGE(ClimaTempo[TempMedia]),
			    ClimaTempo[EhPrevisao] = "Histórico",
			    FILTER(ALL(ClimaTempo), YEAR(ClimaTempo[Date]) = _ano && MONTH(ClimaTempo[Date]) IN _meses)
			)
		formatString: 0.0"°C"
		displayFolder: Clima\Histórico
		lineageTag: 53f4d0ec-f675-4eae-adaf-d5db49811576

	/// Temperatura máxima média no período selecionado (°C). Apenas histórico.
	measure 'Clima Temp Máxima' =
			VAR _anos_sel = ALLSELECTED('01_Calendário'[Ano])
			VAR _ano = IF(COUNTROWS(_anos_sel) = 1, MINX(_anos_sel, '01_Calendário'[Ano]), YEAR(TODAY()))
			VAR _meses = VALUES('01_Calendário'[MêsNúmero])
			RETURN
			CALCULATE(
			    AVERAGE(ClimaTempo[TempMax]),
			    ClimaTempo[EhPrevisao] = "Histórico",
			    FILTER(ALL(ClimaTempo), YEAR(ClimaTempo[Date]) = _ano && MONTH(ClimaTempo[Date]) IN _meses)
			)
		formatString: 0.0"°C"
		displayFolder: Clima\Histórico
		lineageTag: 4ba5d3a7-686a-494a-94e2-fd1d6b704e33

	/// Precipitação total em mm no período. Chuva ≥ 2mm impacta o movimento do parque. Apenas histórico.
	measure 'Clima Chuva Total' =
			VAR _anos_sel = ALLSELECTED('01_Calendário'[Ano])
			VAR _ano = IF(COUNTROWS(_anos_sel) = 1, MINX(_anos_sel, '01_Calendário'[Ano]), YEAR(TODAY()))
			VAR _meses = VALUES('01_Calendário'[MêsNúmero])
			RETURN
			CALCULATE(
			    SUM(ClimaTempo[Precipitacao_mm]),
			    ClimaTempo[EhPrevisao] = "Histórico",
			    FILTER(ALL(ClimaTempo), YEAR(ClimaTempo[Date]) = _ano && MONTH(ClimaTempo[Date]) IN _meses)
			)
		formatString: 0.0" mm"
		displayFolder: Clima\Histórico
		lineageTag: e60ac6a8-ef37-48b3-ae7c-894409faba33

	/// Dias com clima ideal para parque aquático: temp ≥ 25°C e chuva < 2mm. Apenas histórico.
	measure 'Clima Dias Bons Parque' =
			VAR _anos_sel = ALLSELECTED('01_Calendário'[Ano])
			VAR _ano = IF(COUNTROWS(_anos_sel) = 1, MINX(_anos_sel, '01_Calendário'[Ano]), YEAR(TODAY()))
			VAR _meses = VALUES('01_Calendário'[MêsNúmero])
			RETURN
			CALCULATE(
			    COUNTROWS(ClimaTempo),
			    ClimaTempo[BomParaParque] = "Sim",
			    ClimaTempo[EhPrevisao] = "Histórico",
			    FILTER(ALL(ClimaTempo), YEAR(ClimaTempo[Date]) = _ano && MONTH(ClimaTempo[Date]) IN _meses)
			)
		formatString: #,##0
		displayFolder: Clima\Histórico
		lineageTag: bbad1a30-a99c-4c62-a931-de680cbc137f

	/// Dias com chuva significativa (≥ 2mm) no período. Apenas histórico.
	measure 'Clima Dias Chuvosos' =
			VAR _anos_sel = ALLSELECTED('01_Calendário'[Ano])
			VAR _ano = IF(COUNTROWS(_anos_sel) = 1, MINX(_anos_sel, '01_Calendário'[Ano]), YEAR(TODAY()))
			VAR _meses = VALUES('01_Calendário'[MêsNúmero])
			RETURN
			CALCULATE(
			    COUNTROWS(ClimaTempo),
			    ClimaTempo[Precipitacao_mm] >= 2,
			    ClimaTempo[EhPrevisao] = "Histórico",
			    FILTER(ALL(ClimaTempo), YEAR(ClimaTempo[Date]) = _ano && MONTH(ClimaTempo[Date]) IN _meses)
			)
		formatString: #,##0
		displayFolder: Clima\Histórico
		lineageTag: 6b54e5c1-a84d-4359-bbd2-0c16f4bed046

	/// Percentual de dias com clima ideal para parque aquático no período. Apenas histórico.
	measure 'Clima % Dias Bons' =
			VAR _anos_sel = ALLSELECTED('01_Calendário'[Ano])
			VAR _ano = IF(COUNTROWS(_anos_sel) = 1, MINX(_anos_sel, '01_Calendário'[Ano]), YEAR(TODAY()))
			VAR _meses = VALUES('01_Calendário'[MêsNúmero])
			VAR _total =
			    CALCULATE(
			        COUNTROWS(ClimaTempo),
			        ClimaTempo[EhPrevisao] = "Histórico",
			        FILTER(ALL(ClimaTempo), YEAR(ClimaTempo[Date]) = _ano && MONTH(ClimaTempo[Date]) IN _meses)
			    )
			RETURN DIVIDE([Clima Dias Bons Parque], _total)
		formatString: 0.0%
		displayFolder: Clima\Histórico
		lineageTag: 6344dc91-0914-4238-ba8f-0faf27c8cb2c

	/// Temperatura média prevista para os próximos 7 dias (°C).
	measure 'Temp Média Próximos 7d' =
			CALCULATE(
			    AVERAGE(ClimaTempo[TempMedia]),
			    ClimaTempo[EhPrevisao] = "Previsao",
			    DATESINPERIOD('01_Calendário'[Date], TODAY(), 7, DAY)
			)
		formatString: 0.0"°C"
		displayFolder: Clima\Previsão
		lineageTag: 4ae3fe69-c551-470a-8158-7792be38e16b

	/// Dias com clima ideal nos próximos 7 dias. Para antecipar campanhas.
	measure 'Dias Bons Próximos 7d' =
			CALCULATE(
			    COUNTROWS(FILTER(ClimaTempo, ClimaTempo[BomParaParque] = "Sim")),
			    ClimaTempo[EhPrevisao] = "Previsao",
			    DATESINPERIOD('01_Calendário'[Date], TODAY(), 7, DAY)
			)
		formatString: #,##0
		displayFolder: Clima\Previsão
		lineageTag: cb5c678f-537a-45ec-8c37-c6ad53d886a6

	/// Média mensal de precipitação (mm). Agrega por mês e tira a média.
	measure 'Chuva Média Mês' =
			AVERAGEX(
			    VALUES('01_Calendário'[AnoMes]),
			    CALCULATE(SUM(ClimaTempo[Precipitacao_mm]))
			)
		formatString: 0.0" mm"
		displayFolder: Clima\Histórico
		lineageTag: eee3f3de-9c62-477b-93e7-ccf22ca35f8c

	/// ROAS específico do Meta Ads. Retorna 0 enquanto [Receita Limber] for placeholder.
	measure 'ROAS Meta' =
			VAR _receita = [Receita Limber]
			VAR _investimento = [Meta Investimento Total]
			RETURN
			    IF(_receita > 0 && _investimento > 0, DIVIDE(_receita, _investimento), 0)
		formatString: 0.00"x"
		displayFolder: Tráfego Pago Consolidado\ROI por Canal
		lineageTag: 1b55697c-c8c6-4c84-ba07-a247dc74f31e

	/// Total de conversões registradas no Google Ads. Filtrado pelo ano selecionado (ou ano corrente por padrão).
	measure 'GA Conversões' =
			VAR _anos_sel = ALLSELECTED('01_Calendário'[Ano])
			VAR _ano = IF(COUNTROWS(_anos_sel) = 1, MINX(_anos_sel, '01_Calendário'[Ano]), YEAR(TODAY()))
			RETURN
			CALCULATE(
			    SUM(Google_Ads_Campanhas[conversions]),
			    KEEPFILTERS('01_Calendário'[Ano] = _ano)
			)
		formatString: #,##0
		displayFolder: Google Ads
		lineageTag: a1b2c3d4-e5f6-7890-abcd-ef1234567003

	/// ROAS específico do Google Ads. Retorna 0 enquanto [Receita Limber] for placeholder.
	measure 'ROAS Google' =
			VAR _receita = [Receita Limber]
			VAR _investimento = [GA Investimento]
			RETURN
			    IF(_receita > 0 && _investimento > 0, DIVIDE(_receita, _investimento), 0)
		formatString: 0.00"x"
		displayFolder: Tráfego Pago Consolidado\ROI por Canal
		lineageTag: 66e7b13e-697c-486f-87b0-dd296afb2ea2

	/// Alcance único FB (page_impressions_unique). Disponivel desde jan/2026 (carga histórica iniciada em 14/04/2026).
	measure 'FB Alcance Único' =
			VAR _anoMax = MAXX(ALLSELECTED('01_Calendário'), '01_Calendário'[Ano])
			VAR _v = CALCULATE(
			    SUM(Meta_Organico_FB[valor]),
			    Meta_Organico_FB[metrica] = "page_impressions_unique",
			    REMOVEFILTERS('01_Calendário'[Ano]),
			    '01_Calendário'[Ano] = _anoMax
			)
			RETURN IF(ISBLANK(_v), BLANK(), _v)
		formatString: #,##0
		displayFolder: Orgânico FB
		lineageTag: 896c8adf-1a33-43cd-a2e2-adc9bdc7e918

	/// Engajamento total da página Facebook (page_post_engagements).
	measure 'FB Engajamento' =
			VAR _anoMax = MAXX(ALLSELECTED('01_Calendário'), '01_Calendário'[Ano])
			VAR _metric = "page_post_engagements"
			RETURN
			    CALCULATE(
			        SUM(Meta_Organico_FB[valor]),
			        Meta_Organico_FB[metrica] = _metric,
			        REMOVEFILTERS('01_Calendário'[Ano]),
			        '01_Calendário'[Ano] = _anoMax
			    )
		formatString: #,##0
		displayFolder: Orgânico FB
		lineageTag: 2e2153d3-3772-4c75-9d42-0176bdeb331c

	/// Visualizações totais da página Facebook (page_views_total).
