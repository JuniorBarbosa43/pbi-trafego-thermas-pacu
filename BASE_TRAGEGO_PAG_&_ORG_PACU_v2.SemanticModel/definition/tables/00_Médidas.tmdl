	measure 'Ticket Médio por Pedido AA' =
			VAR _anos_sel = ALLSELECTED('01_Calendário'[Ano])
			VAR _ano = IF(COUNTROWS(_anos_sel) = 1, MINX(_anos_sel, '01_Calendário'[Ano]), YEAR(TODAY()))
			VAR _receita = CALCULATE(
			    SUM(Limber_Vendas[ValorUnitario]),
			    Limber_Vendas[Status] = "Aprovada",
			    NOT Limber_Vendas[Categoria] IN {"Aluguel de Boia - LOCAL", "Aluguel de Armários", "Pó Colorido"},
			    REMOVEFILTERS('01_Calendário'[Ano]),
			    '01_Calendário'[Ano] = _ano - 1
			)
			VAR _pedidos = CALCULATE(
			    DISTINCTCOUNT(Limber_Vendas[Localizador]),
			    Limber_Vendas[Status] = "Aprovada",
			    NOT Limber_Vendas[Categoria] IN {"Aluguel de Boia - LOCAL", "Aluguel de Armários", "Pó Colorido"},
			    REMOVEFILTERS('01_Calendário'[Ano]),
			    '01_Calendário'[Ano] = _ano - 1
			)
			RETURN DIVIDE(_receita, _pedidos)
		formatString: R$ #,##0.00
		displayFolder: E-commerce\Comparativos
		lineageTag: ec000104-1111-2222-3333-ECOMM000104

	measure 'ROAS Ingressos AA' =
			VAR _anos_sel = ALLSELECTED('01_Calendário'[Ano])
			VAR _ano = IF(COUNTROWS(_anos_sel) = 1, MINX(_anos_sel, '01_Calendário'[Ano]), YEAR(TODAY()))
			VAR _receita = CALCULATE(
			    SUM(Limber_Vendas[ValorUnitario]),
			    Limber_Vendas[Status] = "Aprovada",
			    NOT Limber_Vendas[Categoria] IN {"Aluguel de Boia - LOCAL", "Aluguel de Armários", "Pó Colorido"},
			    REMOVEFILTERS('01_Calendário'[Ano]),
			    '01_Calendário'[Ano] = _ano - 1
			)
			VAR _invest_meta = CALCULATE(
			    SUM(Meta_Ads_Campanhas[spend]),
			    REMOVEFILTERS('01_Calendário'[Ano]),
			    '01_Calendário'[Ano] = _ano - 1
			)
			VAR _invest_ga = CALCULATE(
			    DIVIDE(SUM(Google_Ads_Campanhas[cost_micros]), 1000000),
			    REMOVEFILTERS('01_Calendário'[Ano]),
			    '01_Calendário'[Ano] = _ano - 1
			)
			VAR _invest = _invest_meta + _invest_ga
			RETURN
			IF(_receita > 0 && _invest > 0, DIVIDE(_receita, _invest), BLANK())
		formatString: 0.00"x"
		displayFolder: E-commerce\Comparativos
		lineageTag: ec000105-1111-2222-3333-ECOMM000105

	measure 'CAC (Custo por Venda) AA' =
