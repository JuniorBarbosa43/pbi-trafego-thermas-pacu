	/// ROAS Google Ads do mês anterior.
	measure 'GA ROAS Mês Anterior' =
			VAR _spend = CALCULATE(DIVIDE(SUM(Google_Ads_Campanhas[cost_micros]), 1000000), DATEADD('01_Calendário'[Date], -1, MONTH))
