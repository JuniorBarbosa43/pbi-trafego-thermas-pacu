			VAR _cy = CALCULATE(SUM(Meta_Organico_FB[valor]), Meta_Organico_FB[metrica] = "page_views_total", REMOVEFILTERS('01_Calendário'[Ano]), '01_Calendário'[Ano] = _anoMax)
			VAR _ly = CALCULATE(SUM(Meta_Organico_FB[valor]), Meta_Organico_FB[metrica] = "page_views_total", REMOVEFILTERS('01_Calendário'[Ano]), '01_Calendário'[Ano] = _anoMax - 1, '01_Calendário'[MêsNúmero] <= _mesMax)
