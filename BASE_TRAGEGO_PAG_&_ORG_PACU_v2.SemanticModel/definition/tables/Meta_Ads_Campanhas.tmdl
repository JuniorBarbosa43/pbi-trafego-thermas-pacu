/// Dados de campanhas do Meta Ads (Facebook/Instagram) - fonte: Google Sheets atualizado diariamente
table Meta_Ads_Campanhas
	lineageTag: d4e5f6a7-b8c9-0123-defa-234567890123

	column campaign_id
		dataType: string
		lineageTag: d4e5f6a7-1111-1111-1111-111111111101
		summarizeBy: none
