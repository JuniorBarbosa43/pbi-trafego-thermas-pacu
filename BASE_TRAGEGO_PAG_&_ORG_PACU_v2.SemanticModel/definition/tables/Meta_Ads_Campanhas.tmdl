	partition Meta_Ads_Campanhas = m
		mode: import
		source =
				let
				    Url = "https://docs.google.com/spreadsheets/d/" & pSpreadsheetId & "/gviz/tq?tqx=out:csv&sheet=Meta_Ads_Campanhas&headers=0&locale=en_US",
				    Csv = Csv.Document(Web.Contents(Url), [Delimiter=",", Encoding=65001, QuoteStyle=QuoteStyle.Csv]),
				    Promovido = Table.PromoteHeaders(Csv, [PromoteAllScalars=true]),
				    Cols = Table.ColumnNames(Promovido),
				    NovosNomes = {"campaign_id", "campaign_name", "date_start", "date_stop", "impressions", "reach", "clicks", "spend", "ctr", "leads", "messaging_conversations", "contacts", "complete_registration", "add_to_cart", "initiate_checkout", "purchases", "conversions_total", "purchase_value", "meta_revenue", "meta_roas", "conversion_action_types", "conversion_value_action_types"},
				    Renomeado = Table.RenameColumns(Promovido, List.Zip({List.FirstN(Cols, List.Count(NovosNomes)), NovosNomes})),
				    Tipado = Table.TransformColumnTypes(Renomeado, {
				        {"campaign_id",              type text},
				        {"campaign_name",            type text},
				        {"date_start",               type date},
				        {"date_stop",                type date},
				        {"impressions",              Int64.Type},
				        {"reach",                    Int64.Type},
				        {"clicks",                   Int64.Type},
				        {"spend",                    type number},
				        {"ctr",                      type number},
				        {"leads",                    type number},
				        {"messaging_conversations",  type number},
				        {"contacts",                 type number},
				        {"complete_registration",    type number},
				        {"add_to_cart",              type number},
				        {"initiate_checkout",        type number},
				        {"purchases",                type number},
				        {"conversions_total",        type number},
				        {"purchase_value",           type number},
				        {"meta_revenue",             type number},
				        {"meta_roas",                type number},
				        {"conversion_action_types",  type text},
				        {"conversion_value_action_types", type text}
				    }, "pt-BR")
				in
				    Tipado

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navegação

