              "solid": {
                "color": "#1F2937"
              }
            }
          }
        ],
        "valueAxis": [
          {
            "labelColor": {
              "solid": {
                "color": "#94A3B8"
              }
            },
            "fontSize": 9,
            "gridlineColor": {
              "solid": {
                "color": "#1F2937"
              }
            }
          }
        ],
        "legend": [
          {
            "show": true,
            "labelColor": {
              "solid": {
                "color": "#94A3B8"
